<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PoliceMunicipale.Mobile.Pages.MapPage"
             BackgroundColor="#1a2035">

    <Grid RowDefinitions="Auto,*">
        <Label Grid.Row="0" Text="Carte en direct"
               BackgroundColor="#243050" TextColor="White"
               FontSize="18" FontAttributes="Bold" Padding="16,14"/>

        <WebView Grid.Row="1" x:Name="MapWebView"
                 BackgroundColor="Transparent"/>
    </Grid>
</ContentPage>
