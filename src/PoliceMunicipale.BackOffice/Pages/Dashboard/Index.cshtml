@page
@model PoliceMunicipale.BackOffice.Pages.Dashboard.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Manager";
    var d = Model.Dashboard;
    var hoursJson = JsonSerializer.Serialize(d.MissionsByHour.Select(h => h.Hour + "h"));
    var countsJson = JsonSerializer.Serialize(d.MissionsByHour.Select(h => h.Count));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="fa-solid fa-gauge me-2 text-primary"></i>Dashboard Manager
    </h4>
    <span class="text-muted small">
        <i class="fa-regular fa-clock me-1"></i>@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR")) — @DateTime.Now.ToString("HH:mm")
    </span>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-primary">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Appels aujourd'hui</div>
                    <div class="kpi-value text-primary">@d.CallsToday</div>
                </div>
                <div class="kpi-icon text-primary">
                    <i class="fa-solid fa-phone"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-success">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Missions actives</div>
                    <div class="kpi-value text-success">@d.ActiveMissions</div>
                </div>
                <div class="kpi-icon text-success">
                    <i class="fa-solid fa-car-side"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-info">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Véhicules disponibles</div>
                    <div class="kpi-value text-info">@d.AvailableVehicles</div>
                </div>
                <div class="kpi-icon text-info">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-warning">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Véhicules en mission</div>
                    <div class="kpi-value text-warning">@d.VehiclesOnMission</div>
                </div>
                <div class="kpi-icon text-warning">
                    <i class="fa-solid fa-location-crosshairs"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Graphique missions par heure -->
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-chart-bar me-2 text-primary"></i>Missions par heure (aujourd'hui)
                </h6>
            </div>
            <div class="card-body">
                <canvas id="missionsChart" style="max-height:280px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Top véhicules -->
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-trophy me-2 text-warning"></i>Top 5 véhicules
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Indicatif</th>
                                <th class="text-success text-center">Acceptées</th>
                                <th class="text-danger text-center">Refusées</th>
                                <th class="text-center">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rank = 1; }
                            @foreach (var v in d.TopVehicles)
                            {
                                var rankIcon = rank switch { 1 => "text-warning", 2 => "text-secondary", 3 => "text-danger", _ => "text-muted" };
                                <tr>
                                    <td><i class="fa-solid fa-medal @rankIcon"></i></td>
                                    <td class="fw-semibold">@v.CallSign</td>
                                    <td class="text-center text-success fw-bold">@v.AcceptedCount</td>
                                    <td class="text-center text-danger">@v.RefusedCount</td>
                                    <td class="text-center">
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-success" style="width:@(v.TotalCount > 0 ? (v.AcceptedCount * 100 / v.TotalCount) : 0)%"></div>
                                            <div class="progress-bar bg-danger" style="width:@(v.TotalCount > 0 ? (v.RefusedCount * 100 / v.TotalCount) : 0)%"></div>
                                        </div>
                                        <small class="text-muted">@v.TotalCount</small>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 10 dernières missions -->
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">
            <i class="fa-solid fa-list me-2 text-secondary"></i>10 dernières missions
        </h6>
        <a asp-page="/Missions/Index" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-external-link-alt me-1"></i>Toutes les missions
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Référence</th>
                        <th>Statut</th>
                        <th>Adresse</th>
                        <th>Véhicule</th>
                        <th>Créée</th>
                        <th>Terminée</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in d.RecentMissions)
                    {
                        <tr>
                            <td class="fw-semibold">@m.Reference</td>
                            <td>
                                @{ ViewData["Status"] = m.Status; }
                                @await Html.PartialAsync("_StatusBadge")
                            </td>
                            <td>@m.TargetAddress</td>
                            <td>@(m.AssignedVehicleCallSign ?? "—")</td>
                            <td>@m.CreatedAt.ToLocalTime().ToString("HH:mm")</td>
                            <td>@(m.CompletedAt?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                            <td>
                                <a asp-page="/Missions/Details" asp-route-id="@m.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        var ctx = document.getElementById('missionsChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(hoursJson),
                datasets: [{
                    label: 'Missions',
                    data: @Html.Raw(countsJson),
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderColor: 'rgba(13,110,253,1)',
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y + ' mission(s)'
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 },
                        title: { display: true, text: 'Nb missions' }
                    },
                    x: {
                        title: { display: true, text: 'Heure' }
                    }
                }
            }
        });
    })();
    </script>
}
