@page
@model PoliceMunicipale.BackOffice.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="fa-solid fa-users me-2 text-primary"></i>Gestion des utilisateurs
        <span class="badge bg-secondary ms-2">@Model.Users.Count</span>
    </h4>
    <a asp-page="/Admin/Users/Edit" class="btn btn-primary">
        <i class="fa-solid fa-user-plus me-2"></i>Nouvel utilisateur
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Matricule</th>
                        <th>Nom complet</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        var roleColor = u.Role switch
                        {
                            "Admin" => "bg-danger",
                            "Manager" => "bg-warning text-dark",
                            "Operator" => "bg-info text-dark",
                            _ => "bg-secondary"
                        };
                        <tr class="@(!u.IsActive ? "table-secondary text-muted" : "")">
                            <td class="fw-semibold font-monospace">@u.BadgeNumber</td>
                            <td>
                                <i class="fa-solid fa-user-circle me-2 text-secondary"></i>
                                <strong>@u.FullName</strong>
                            </td>
                            <td>
                                <a href="mailto:@u.Email" class="text-decoration-none">@u.Email</a>
                            </td>
                            <td>
                                <span class="badge @roleColor">@u.Role</span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success">
                                        <i class="fa-solid fa-circle-check me-1"></i>Actif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="fa-solid fa-circle-xmark me-1"></i>Inactif
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="/Admin/Users/Edit" asp-route-id="@u.Id"
                                   class="btn btn-sm btn-outline-warning" title="Modifier">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form method="post" asp-page-handler="ToggleActive" asp-route-id="@u.Id"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-secondary" : "btn-outline-success")"
                                            title="@(u.IsActive ? "Désactiver" : "Activer")">
                                        <i class="fa-solid @(u.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                                Aucun utilisateur enregistré.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
