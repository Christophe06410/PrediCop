<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PublishProtocol>MSDeploy</PublishProtocol>
    <PublishSiteName>predicop</PublishSiteName>
    <MSDeployServiceURL>predicop-gvb7fjbhhwe2h8bj.scm.westeurope-01.azurewebsites.net:443</MSDeployServiceURL>
    <DeployIisAppPath>predicop</DeployIisAppPath>
    <UserName>$predicop</UserName>
    <PublishFramework>net10.0</PublishFramework>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <Configuration>Release</Configuration>
    <EnvironmentName>Production</EnvironmentName>
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <EnableMSDeployAppOffline>true</EnableMSDeployAppOffline>
  </PropertyGroup>
</Project>
