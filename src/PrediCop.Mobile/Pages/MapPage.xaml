<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrediCop.Mobile.Pages.MapPage"
             BackgroundColor="#1a2035">

    <Grid RowDefinitions="Auto,*">
        <Label Grid.Row="0" Text="Carte en direct"
               BackgroundColor="#243050" TextColor="White"
               FontSize="18" FontAttributes="Bold" Padding="16,14"/>

        <WebView Grid.Row="1" x:Name="MapWebView"
                 BackgroundColor="Transparent"/>

        <!-- Visible uniquement quand un point est focalisé (depuis patrouille) -->
        <Button x:Name="DirectionsButton"
                Grid.Row="1"
                IsVisible="False"
                Text="Itineraire GPS"
                BackgroundColor="#2563eb"
                TextColor="White"
                CornerRadius="24"
                Padding="20,10"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,24"
                Clicked="OnDirectionsClicked"/>
    </Grid>
</ContentPage>
