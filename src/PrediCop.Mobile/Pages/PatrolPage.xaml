<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrediCop.Mobile.Pages.PatrolPage"
             BackgroundColor="#1a2035">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#243050" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Text="Rues à Patrouiller" TextColor="White"
                   FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
            <Button Grid.Column="1" Text="Actualiser"
                    BackgroundColor="#2563eb" TextColor="White"
                    CornerRadius="8" Padding="12,6"
                    FontSize="13" Clicked="OnRefreshClicked"/>
        </Grid>

        <CollectionView Grid.Row="1" x:Name="StreetsCollection"
                        Margin="0" BackgroundColor="Transparent">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="12,6" Padding="0" CornerRadius="12"
                           BackgroundColor="#1e2d4a" HasShadow="False">
                        <Grid ColumnDefinitions="8,*,Auto" ColumnSpacing="0">
                            <!-- Risk color bar -->
                            <BoxView Grid.Column="0"
                                     Color="{Binding RiskColor}"
                                     CornerRadius="12,0,0,12"/>
                            <VerticalStackLayout Grid.Column="1" Padding="14,12" Spacing="4">
                                <Label Text="{Binding Name}"
                                       TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="{Binding District}"
                                       TextColor="#aab0c0" FontSize="13"/>
                                <Label Text="{Binding LastPatrolText}"
                                       TextColor="#6b7a99" FontSize="12"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Padding="14,12"
                                                 HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="{Binding RiskScore}"
                                       TextColor="{Binding RiskColor}"
                                       FontSize="24" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="RISQUE" TextColor="#6b7a99"
                                       FontSize="9" HorizontalTextAlignment="Center"/>
                                <Button Text="Passé" BackgroundColor="#374151" TextColor="White"
                                        CornerRadius="6" Padding="8,4" FontSize="12"
                                        CommandParameter="{Binding StreetId}"
                                        Clicked="OnPatrolledClicked"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
