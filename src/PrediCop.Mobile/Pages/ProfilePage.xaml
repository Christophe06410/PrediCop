<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrediCop.Mobile.Pages.ProfilePage"
             BackgroundColor="#1a2035">

    <VerticalStackLayout Padding="24" Spacing="20">

        <Frame BackgroundColor="#243050" CornerRadius="16" Padding="20" HasShadow="False">
            <VerticalStackLayout Spacing="8">
                <Label Text="Mon Profil" TextColor="White"
                       FontSize="18" FontAttributes="Bold"/>
                <Label Text="{Binding UserName}" TextColor="#93c5fd" FontSize="16"/>
                <Label Text="{Binding Badge}" TextColor="#6b7a99" FontSize="13"/>
            </VerticalStackLayout>
        </Frame>

        <Frame BackgroundColor="#243050" CornerRadius="16" Padding="20" HasShadow="False">
            <VerticalStackLayout Spacing="12">
                <Label Text="Paramètres" TextColor="White"
                       FontSize="16" FontAttributes="Bold"/>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Notifications missions" TextColor="#aab0c0"
                           VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="True" OnColor="#2563eb"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Suivi GPS actif" TextColor="#aab0c0"
                           VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="True"
                            OnColor="#2563eb" Toggled="OnGpsToggled"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <Button Text="Changer mon mot de passe" BackgroundColor="#1e3a5f" TextColor="White"
                CornerRadius="12" HeightRequest="50" Clicked="OnChangePasswordClicked"/>

        <Button Text="Se déconnecter" BackgroundColor="#374151" TextColor="White"
                CornerRadius="12" HeightRequest="50" Clicked="OnLogoutClicked"/>
    </VerticalStackLayout>
</ContentPage>
