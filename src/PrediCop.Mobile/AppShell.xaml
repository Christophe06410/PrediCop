<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PrediCop.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:PrediCop.Mobile.Pages"
    Title="PrediCop"
    FlyoutBehavior="Disabled">

    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#1a2035"/>
            <Setter Property="Shell.TabBarForegroundColor" Value="#2563eb"/>
            <Setter Property="Shell.TabBarUnselectedColor" Value="#6b7a99"/>
            <Setter Property="Shell.TabBarTitleColor" Value="#aab0c0"/>
        </Style>
    </Shell.Resources>

    <!-- Login (sans barre d'onglets) -->
    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate pages:LoginPage}"
                  Shell.NavBarIsVisible="False"
                  Shell.TabBarIsVisible="False" />

    <!-- Application principale -->
    <TabBar x:Name="MainTabBar" Route="main">

        <!-- Onglets Officer (patrouille) -->
        <Tab x:Name="TabMissions" Route="missions" Title="Missions">
            <ShellContent ContentTemplate="{DataTemplate pages:MissionPage}"
                          Shell.NavBarIsVisible="False" />
        </Tab>
        <Tab x:Name="TabPatrol" Route="patrol" Title="Patrouille">
            <ShellContent ContentTemplate="{DataTemplate pages:PatrolPage}"
                          Shell.NavBarIsVisible="False" />
        </Tab>
        <Tab x:Name="TabMap" Route="map" Title="Carte">
            <ShellContent ContentTemplate="{DataTemplate pages:MapPage}"
                          Shell.NavBarIsVisible="False" />
        </Tab>

        <!-- Onglet Verbalisation — caché par défaut, affiché si module activé -->
        <Tab x:Name="TabTickets" Route="tickets" Title="PV" IsVisible="False">
            <ShellContent ContentTemplate="{DataTemplate pages:TicketingPage}"
                          Shell.NavBarIsVisible="False" />
        </Tab>

        <!-- Profil — toujours visible -->
        <Tab x:Name="TabProfile" Route="profile" Title="Profil">
            <ShellContent ContentTemplate="{DataTemplate pages:ProfilePage}"
                          Shell.NavBarIsVisible="False" />
        </Tab>

    </TabBar>

</Shell>
