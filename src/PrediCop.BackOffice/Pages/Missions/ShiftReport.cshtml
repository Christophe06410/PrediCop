@page
@model PrediCop.BackOffice.Pages.Missions.ShiftReportModel
@{
    ViewData["Title"] = "Rapport de fin de vacation";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Missions/Index">Missions</a></li>
            <li class="breadcrumb-item active">Rapport de vacation</li>
        </ol>
    </nav>
</div>

<div class="row g-3">
    <!-- Formulaire de génération -->
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-file-contract me-2 text-primary"></i>Générer un rapport de vacation
                </h6>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" asp-page-handler="Generate">
                    <div class="mb-3">
                        <label asp-for="VehicleId" class="form-label fw-semibold small">
                            <i class="fa-solid fa-car me-1 text-secondary"></i>Véhicule
                        </label>
                        <select asp-for="VehicleId" class="form-select form-select-sm">
                            <option value="">— Sélectionner un véhicule —</option>
                            @foreach (var v in Model.Vehicles)
                            {
                                <option value="@v.Id">
                                    @v.CallSign — @v.LicensePlate
                                    @if (v.OfficerNames.Any())
                                    {
                                        @(" (" + string.Join(", ", v.OfficerNames) + ")")
                                    }
                                </option>
                            }
                        </select>
                        <span asp-validation-for="VehicleId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ShiftStart" class="form-label fw-semibold small">
                            <i class="fa-solid fa-clock me-1 text-secondary"></i>Début de vacation
                        </label>
                        <input asp-for="ShiftStart" type="datetime-local" class="form-control form-control-sm"
                               value="@Model.ShiftStart.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="ShiftStart" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ShiftEnd" class="form-label fw-semibold small">
                            <i class="fa-solid fa-flag-checkered me-1 text-secondary"></i>Fin de vacation
                        </label>
                        <input asp-for="ShiftEnd" type="datetime-local" class="form-control form-control-sm"
                               value="@Model.ShiftEnd.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="ShiftEnd" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold small">
                            <i class="fa-solid fa-pen-to-square me-1 text-secondary"></i>Notes (optionnel)
                        </label>
                        <textarea asp-for="Notes" class="form-control form-control-sm" rows="4" data-text-assistant
                                  maxlength="4000"
                                  placeholder="Commentaires libres sur la vacation...">@Model.Notes</textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Générer le rapport
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Résultat du rapport généré -->
    <div class="col-lg-7">
        @if (Model.GeneratedReport is not null)
        {
            var r = Model.GeneratedReport;
            var duration = r.Duration;
            <div class="card shadow-sm border-start border-4 @(r.IsSigned ? "border-success" : "border-primary")">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold">
                        <i class="fa-solid fa-clipboard-check me-2 @(r.IsSigned ? "text-success" : "text-primary")"></i>
                        Rapport — @r.VehicleCallSign
                    </h6>
                    <div class="d-flex gap-2 align-items-center">
                        @if (r.IsSigned)
                        {
                            <span class="badge bg-success">
                                <i class="fa-solid fa-signature me-1"></i>Signé le @r.SignedAt!.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </span>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Sign" asp-route-reportId="@r.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success"
                                        onclick="return confirm('Signer électroniquement ce rapport ? Cette action est irréversible.')">
                                    <i class="fa-solid fa-signature me-1"></i>Signer
                                </button>
                            </form>
                        }
                        <a asp-page="/Missions/ShiftReportExport" asp-route-id="@r.Id" target="_blank"
                           class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>PDF
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <!-- En-tête vacation -->
                    <div class="row g-2 mb-3">
                        <div class="col-sm-6">
                            <div class="p-2 bg-light rounded">
                                <div class="text-muted small mb-1">
                                    <i class="fa-solid fa-car me-1"></i>Véhicule
                                </div>
                                <div class="fw-semibold">@r.VehicleCallSign</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 bg-light rounded">
                                <div class="text-muted small mb-1">
                                    <i class="fa-solid fa-user-shield me-1"></i>Agents
                                </div>
                                <div class="fw-semibold">
                                    @(string.IsNullOrEmpty(r.OfficerNames) ? "—" : r.OfficerNames)
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 bg-light rounded">
                                <div class="text-muted small mb-1">
                                    <i class="fa-solid fa-clock me-1"></i>Début
                                </div>
                                <div class="fw-semibold">@r.ShiftStart.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-2 bg-light rounded">
                                <div class="text-muted small mb-1">
                                    <i class="fa-solid fa-flag-checkered me-1"></i>Fin
                                </div>
                                <div class="fw-semibold">@r.ShiftEnd.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                    </div>

                    <!-- Durée -->
                    <div class="alert alert-info py-2 mb-3">
                        <i class="fa-solid fa-hourglass-half me-2"></i>
                        <strong>Durée totale :</strong>
                        @((int)duration.TotalHours)h @duration.Minutes.ToString("D2")min
                    </div>

                    <!-- KPIs -->
                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3">
                            <div class="card text-center border-0 bg-primary bg-opacity-10 h-100">
                                <div class="card-body py-2 px-1">
                                    <div class="fs-3 fw-bold text-primary">@r.MissionCount</div>
                                    <div class="small text-muted">Missions</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card text-center border-0 bg-success bg-opacity-10 h-100">
                                <div class="card-body py-2 px-1">
                                    <div class="fs-3 fw-bold text-success">@r.CompletedMissionCount</div>
                                    <div class="small text-muted">Terminées</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card text-center border-0 bg-danger bg-opacity-10 h-100">
                                <div class="card-body py-2 px-1">
                                    <div class="fs-3 fw-bold text-danger">@r.RefusedMissionCount</div>
                                    <div class="small text-muted">Refusées</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card text-center border-0 bg-warning bg-opacity-10 h-100">
                                <div class="card-body py-2 px-1">
                                    <div class="fs-3 fw-bold text-warning">@r.DocumentCount</div>
                                    <div class="small text-muted">Documents</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Patrouilles & km -->
                    <div class="row g-2 mb-3">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center p-2 bg-light rounded gap-3">
                                <i class="fa-solid fa-map-location-dot fa-2x text-info"></i>
                                <div>
                                    <div class="fw-bold fs-5">@r.PatrolRecordCount</div>
                                    <div class="text-muted small">Passages de rues</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center p-2 bg-light rounded gap-3">
                                <i class="fa-solid fa-route fa-2x text-info"></i>
                                <div>
                                    <div class="fw-bold fs-5">@r.EstimatedKm.ToString("F1") km</div>
                                    <div class="text-muted small">Distance estimée</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notes -->
                    @if (!string.IsNullOrWhiteSpace(r.Notes))
                    {
                        <div class="mt-2">
                            <h6 class="fw-semibold small text-muted text-uppercase">
                                <i class="fa-solid fa-pen-to-square me-1"></i>Notes de l'agent
                            </h6>
                            <div class="p-2 bg-light rounded" style="white-space:pre-line">@r.Notes</div>
                        </div>
                    }

                    <div class="text-muted small mt-3">
                        <i class="fa-solid fa-calendar-check me-1"></i>Rapport généré le @r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy à HH:mm")
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-muted py-5">
                    <i class="fa-solid fa-file-contract fa-3x mb-3 opacity-25"></i>
                    <p class="mb-0">Remplissez le formulaire et cliquez sur <strong>Générer le rapport</strong> pour afficher le résumé de vacation.</p>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
