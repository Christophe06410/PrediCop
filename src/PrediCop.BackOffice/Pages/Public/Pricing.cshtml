@page
@model PrediCop.BackOffice.Pages.Public.PricingModel
@{
    ViewData["Title"] = "Tarifs — PrediCop";
    Layout = "~/Pages/Shared/_LandingLayout.cshtml";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Tarifs simples et transparents</h1>
        <p class="text-muted">Sans frais cachés. Changez de formule à tout moment.</p>

        <div class="d-flex align-items-center justify-content-center gap-3 mt-4">
            <span class="fw-semibold" id="lbl-monthly">Mensuel</span>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="billingToggle" role="switch" />
            </div>
            <span class="text-muted" id="lbl-yearly">Annuel <span class="badge bg-success">-15%</span></span>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Essential -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 shadow-sm pricing-card">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="badge bg-secondary mb-2">Essentiel</span>
                        <div class="d-flex align-items-end gap-1">
                            <span class="display-5 fw-bold" id="price-essential">89 €</span>
                            <span class="text-muted mb-2" id="period-essential">/mois</span>
                        </div>
                        <small class="text-muted" id="yearly-note-essential" style="display:none">soit 909 €/an (au lieu de 1 068 €)</small>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>5 véhicules</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>5 utilisateurs</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Réception d'appels</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Dispatch missions</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Suivi GPS</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Export PDF &amp; Word</li>
                        <li class="mb-2 text-muted"><i class="fa-solid fa-times me-2"></i>Indice de risque avancé</li>
                        <li class="mb-2 text-muted"><i class="fa-solid fa-times me-2"></i>Dashboard manager</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary w-100 signup-btn" data-plan="Essential">Choisir Essentiel</a>
                </div>
            </div>
        </div>

        <!-- Standard -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 shadow-sm pricing-card featured">
                <div class="card-header bg-primary text-white text-center py-2 fw-semibold">
                    <i class="fa-solid fa-star me-1"></i>Plus populaire
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="badge bg-primary mb-2">Standard</span>
                        <div class="d-flex align-items-end gap-1">
                            <span class="display-5 fw-bold" id="price-standard">199 €</span>
                            <span class="text-muted mb-2" id="period-standard">/mois</span>
                        </div>
                        <small class="text-muted" id="yearly-note-standard" style="display:none">soit 2 030 €/an (au lieu de 2 388 €)</small>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>20 véhicules</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Utilisateurs illimités</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Réception d'appels</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Dispatch missions</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Suivi GPS</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Export PDF &amp; Word</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Indice de risque avancé</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Dashboard manager</li>
                    </ul>
                    <a href="#" class="btn btn-primary w-100 signup-btn" data-plan="Standard">Choisir Standard</a>
                </div>
            </div>
        </div>

        <!-- Premium -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 shadow-sm pricing-card">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="badge bg-dark mb-2">Premium</span>
                        <div class="d-flex align-items-end gap-1">
                            <span class="display-5 fw-bold">Sur devis</span>
                        </div>
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Véhicules illimités</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Utilisateurs illimités</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Toutes les fonctionnalités</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Support prioritaire</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Formation incluse</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>SLA personnalisé</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Intégrations sur mesure</li>
                        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Hébergement dédié (option)</li>
                    </ul>
                    <a href="mailto:contact@predicop.fr" class="btn btn-outline-dark w-100">Contacter le commercial</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modules optionnels -->
<div class="bg-light py-5">
    <div class="container">
        <div class="text-center mb-4">
            <span class="badge bg-warning text-dark px-3 py-2 mb-3">Modules optionnels</span>
            <h2 class="fw-bold">Personnalisez votre abonnement</h2>
            <p class="text-muted">Cochez les modules dont votre service a besoin. Activables à tout moment depuis l'administration.</p>
        </div>

        <div class="row g-4" id="modules-grid">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm module-card"
                     data-module="rh" data-price="39" data-name="Module RH"
                     role="button" tabindex="0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-users-gear fa-lg text-warning"></i>
                            <h5 class="fw-semibold mb-0 flex-grow-1">Module RH</h5>
                            <span class="badge bg-warning text-dark">+39 €/mois</span>
                            <i class="fa-regular fa-square-check module-check-icon fs-5 text-muted ms-1"></i>
                        </div>
                        <p class="text-muted mb-0 small">Plannings des vacations, gestion des congés, profils d'urgence (groupe sanguin, contacts). Workflow d'approbation intégré.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm module-card"
                     data-module="verbalisation" data-price="49" data-name="Verbalisation électronique"
                     role="button" tabindex="0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-ticket fa-lg text-warning"></i>
                            <h5 class="fw-semibold mb-0 flex-grow-1">Verbalisation électronique</h5>
                            <span class="badge bg-warning text-dark">+49 €/mois</span>
                            <i class="fa-regular fa-square-check module-check-icon fs-5 text-muted ms-1"></i>
                        </div>
                        <p class="text-muted mb-0 small">PV électroniques signés depuis le mobile, numérotation automatique, statistiques et export ANTAI (CSV/Excel).</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm module-card"
                     data-module="fourriere" data-price="29" data-name="Module Fourrière"
                     role="button" tabindex="0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-warehouse fa-lg text-warning"></i>
                            <h5 class="fw-semibold mb-0 flex-grow-1">Module Fourrière</h5>
                            <span class="badge bg-warning text-dark">+29 €/mois</span>
                            <i class="fa-regular fa-square-check module-check-icon fs-5 text-muted ms-1"></i>
                        </div>
                        <p class="text-muted mb-0 small">Enregistrement des enlèvements, constats d'état, suivi du cycle de vie des véhicules, statistiques de la fourrière.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm module-card"
                     data-module="fleet" data-price="29" data-name="Gestion de flotte"
                     role="button" tabindex="0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-car-on fa-lg text-warning"></i>
                            <h5 class="fw-semibold mb-0 flex-grow-1">Gestion de flotte</h5>
                            <span class="badge bg-warning text-dark">+29 €/mois</span>
                            <i class="fa-regular fa-square-check module-check-icon fs-5 text-muted ms-1"></i>
                        </div>
                        <p class="text-muted mb-0 small">Carnet de bord numérique, révisions planifiées, contrôles techniques, alertes d'échéances et historique des coûts.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm module-card"
                     data-module="logistics" data-price="25" data-name="Module Logistique"
                     role="button" tabindex="0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-box-open fa-lg text-warning"></i>
                            <h5 class="fw-semibold mb-0 flex-grow-1">Module Logistique</h5>
                            <span class="badge bg-warning text-dark">+25 €/mois</span>
                            <i class="fa-regular fa-square-check module-check-icon fs-5 text-muted ms-1"></i>
                        </div>
                        <p class="text-muted mb-0 small">Catalogue d'équipements, dotations avec expiration, fiches de tailles uniformes et alertes de renouvellement.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm module-card"
                     data-module="geofencing" data-price="19" data-name="Géofencing"
                     role="button" tabindex="0">
                    <div class="card-body p-3 d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa-solid fa-draw-polygon fa-lg text-info"></i>
                            <h5 class="fw-semibold mb-0 flex-grow-1">Géofencing</h5>
                            <span class="badge bg-info text-dark">+19 €/mois</span>
                            <i class="fa-regular fa-square-check module-check-icon fs-5 text-muted ms-1"></i>
                        </div>
                        <p class="text-muted mb-0 small">Alertes automatiques lorsqu'un véhicule sort de sa zone de patrouille assignée. Notification SignalR + email manager.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total dynamique + CTA -->
        <div class="mt-5 text-center">
            <div id="modules-summary" class="d-none mb-4">
                <div class="d-inline-block bg-white border rounded-3 shadow-sm px-4 py-3">
                    <div class="text-muted small mb-1">Modules sélectionnés</div>
                    <div id="selected-modules-list" class="fw-semibold mb-2"></div>
                    <div class="fs-5">
                        Total modules : <strong id="modules-total" class="text-warning">0 €</strong>/mois
                    </div>
                    <div id="modules-total-yearly" class="text-muted small" style="display:none"></div>
                </div>
            </div>
            <p class="text-muted mb-1">Les modules sont facturés en supplément de votre abonnement de base.</p>
            <p class="text-muted small mb-4">Réduction annuelle de 15% applicable sur les modules optionnels.</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a href="#" class="btn btn-outline-primary btn-lg px-4 signup-btn" data-plan="Essential">
                    <i class="fa-solid fa-rocket me-2"></i>Démarrer avec Essentiel
                </a>
                <a href="#" class="btn btn-warning btn-lg px-4 signup-btn" data-plan="Standard">
                    <i class="fa-solid fa-rocket me-2"></i>Démarrer avec Standard
                </a>
            </div>
        </div>
    </div>
</div>

<div class="bg-primary text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">Des questions sur les tarifs ?</h2>
        <p class="mb-4 opacity-75">Notre équipe vous accompagne pour trouver la configuration adaptée à votre PM.</p>
        <a href="mailto:contact@predicop.fr" class="btn btn-light btn-lg px-5">Contacter le commercial</a>
    </div>
</div>

<style>
.module-card {
    cursor: pointer;
    transition: border-color .15s, box-shadow .15s;
    border: 2px solid transparent !important;
}
.module-card:hover {
    border-color: #ffc107 !important;
}
.module-card.selected {
    border-color: #ffc107 !important;
    background-color: #fffdf0 !important;
}
.module-card.selected .module-check-icon {
    color: #198754 !important;
}
.module-card.selected .module-check-icon::before {
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
    content: "\f14a";
}
</style>

@section Scripts {
<script>
(function() {
    var yearly = false;
    var selectedModules = {};
    var basePrices   = { essential: [89, 909], standard: [199, 2030] };
    var modulePrices = {};

    // Collect module prices from data attributes
    document.querySelectorAll('.module-card').forEach(function(card) {
        modulePrices[card.dataset.module] = parseInt(card.dataset.price, 10);
    });

    // ---- Billing toggle ----
    var toggle = document.getElementById('billingToggle');
    toggle.addEventListener('change', function() { yearly = this.checked; updateAll(); });

    // ---- Module selection ----
    document.querySelectorAll('.module-card').forEach(function(card) {
        function toggle() {
            var m = card.dataset.module;
            if (selectedModules[m]) {
                delete selectedModules[m];
                card.classList.remove('selected');
            } else {
                selectedModules[m] = { name: card.dataset.name, price: parseInt(card.dataset.price, 10) };
                card.classList.add('selected');
            }
            updateAll();
        }
        card.addEventListener('click', toggle);
        card.addEventListener('keydown', function(e) { if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggle(); } });
    });

    function updateAll() {
        updatePrices();
        updateModulesSummary();
        updateSignupLinks();
    }

    function updatePrices() {
        ['essential','standard'].forEach(function(plan) {
            var p = document.getElementById('price-' + plan);
            var per = document.getElementById('period-' + plan);
            var note = document.getElementById('yearly-note-' + plan);
            if (yearly) {
                p.textContent = basePrices[plan][1].toLocaleString('fr-FR') + ' €';
                per.textContent = '/an';
                note.style.display = '';
            } else {
                p.textContent = basePrices[plan][0] + ' €';
                per.textContent = '/mois';
                note.style.display = 'none';
            }
        });
        document.getElementById('lbl-monthly').className = yearly ? 'text-muted fw-normal' : 'fw-semibold';
        document.getElementById('lbl-yearly').className  = yearly ? 'fw-semibold' : 'text-muted';
    }

    function updateModulesSummary() {
        var keys = Object.keys(selectedModules);
        var summary = document.getElementById('modules-summary');
        var list    = document.getElementById('selected-modules-list');
        var total   = document.getElementById('modules-total');
        var totalYr = document.getElementById('modules-total-yearly');

        if (keys.length === 0) {
            summary.classList.add('d-none');
            return;
        }
        summary.classList.remove('d-none');

        var monthlyExtra = keys.reduce(function(s, k) { return s + selectedModules[k].price; }, 0);
        var yearlyExtra  = Math.round(monthlyExtra * 12 * 0.85);

        list.textContent = keys.map(function(k) { return selectedModules[k].name; }).join(', ');
        total.textContent = monthlyExtra + ' €';
        if (yearly) {
            totalYr.textContent = 'soit ' + yearlyExtra.toLocaleString('fr-FR') + ' €/an (-15%)';
            totalYr.style.display = '';
        } else {
            totalYr.style.display = 'none';
        }
    }

    function updateSignupLinks() {
        var keys = Object.keys(selectedModules);
        var modulesParam = keys.length > 0 ? '&modules=' + keys.join(',') : '';
        document.querySelectorAll('.signup-btn').forEach(function(btn) {
            var plan = btn.dataset.plan;
            btn.href = '/Public/Signup?plan=' + plan + '&period=' + (yearly ? 'Yearly' : 'Monthly') + modulesParam;
        });
    }

    updateAll();
})();
</script>
}
