@page
@model PrediCop.BackOffice.Pages.Public.Signup.SuccessModel
@{
    ViewData["Title"] = "Compte créé — PrediCop";
    Layout = "~/Pages/Shared/_LandingLayout.cshtml";
}
<div class="container py-5 text-center">
    <div class="card shadow border-0 mx-auto" style="max-width:500px">
        <div class="card-body p-5">
            <i class="fa-solid fa-circle-check text-success mb-3" style="font-size:4rem"></i>
            <h2 class="fw-bold mb-3">Votre compte est activé !</h2>
            <p class="text-muted mb-4">Votre paiement a été confirmé. Connectez-vous dès maintenant avec les identifiants que vous venez de créer.</p>
            <a asp-page="/Account/Login" class="btn btn-primary btn-lg px-5">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Se connecter
            </a>
        </div>
    </div>
</div>
