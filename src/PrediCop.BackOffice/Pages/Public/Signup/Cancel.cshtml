@page
@model PrediCop.BackOffice.Pages.Public.Signup.CancelModel
@{
    ViewData["Title"] = "Paiement annulé — PrediCop";
    Layout = "~/Pages/Shared/_LandingLayout.cshtml";
}
<div class="container py-5 text-center">
    <div class="card shadow border-0 mx-auto" style="max-width:500px">
        <div class="card-body p-5">
            <i class="fa-solid fa-circle-xmark text-warning mb-3" style="font-size:4rem"></i>
            <h2 class="fw-bold mb-3">Paiement annulé</h2>
            <p class="text-muted mb-4">Votre paiement n'a pas été complété. Aucun montant n'a été débité.</p>
            <div class="d-flex gap-3 justify-content-center">
                <a asp-page="/Public/Pricing" class="btn btn-primary">Réessayer</a>
                <a asp-page="/Public/Index" class="btn btn-outline-secondary">Retour à l'accueil</a>
            </div>
        </div>
    </div>
</div>
