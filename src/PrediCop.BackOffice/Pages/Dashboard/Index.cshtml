@page
@model PrediCop.BackOffice.Pages.Dashboard.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Manager";
    var d = Model.Dashboard;
    var ts = Model.TimeSeriesStats;
    var hoursJson = JsonSerializer.Serialize(d.MissionsByHour.Select(h => h.Hour + "h"));
    var countsJson = JsonSerializer.Serialize(d.MissionsByHour.Select(h => h.Count));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="fa-solid fa-gauge me-2 text-primary"></i>Dashboard Manager
    </h4>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted small">
            <i class="fa-regular fa-clock me-1"></i>@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR")) — @DateTime.Now.ToString("HH:mm")
        </span>
        <a asp-page="/Dashboard/Export" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-file-export me-1"></i>Exporter
        </a>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-primary">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Mains courantes aujourd'hui</div>
                    <div class="kpi-value text-primary">@d.CallsToday</div>
                </div>
                <div class="kpi-icon text-primary">
                    <i class="fa-solid fa-phone"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-success">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Missions actives</div>
                    <div class="kpi-value text-success">@d.ActiveMissions</div>
                </div>
                <div class="kpi-icon text-success">
                    <i class="fa-solid fa-car-side"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-info">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Véhicules disponibles</div>
                    <div class="kpi-value text-info">@d.AvailableVehicles</div>
                </div>
                <div class="kpi-icon text-info">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card shadow-sm kpi-card border-start border-4 border-warning">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Véhicules en mission</div>
                    <div class="kpi-value text-warning">@d.VehiclesOnMission</div>
                </div>
                <div class="kpi-icon text-warning">
                    <i class="fa-solid fa-location-crosshairs"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Graphique missions par heure -->
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-chart-bar me-2 text-primary"></i>Missions par heure (aujourd'hui)
                </h6>
            </div>
            <div class="card-body">
                <canvas id="missionsChart" style="max-height:280px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Top véhicules -->
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-trophy me-2 text-warning"></i>Top 5 véhicules
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Indicatif</th>
                                <th class="text-success text-center">Acceptées</th>
                                <th class="text-danger text-center">Refusées</th>
                                <th class="text-center">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rank = 1; }
                            @foreach (var v in d.TopVehicles)
                            {
                                var rankIcon = rank switch { 1 => "text-warning", 2 => "text-secondary", 3 => "text-danger", _ => "text-muted" };
                                <tr>
                                    <td><i class="fa-solid fa-medal @rankIcon"></i></td>
                                    <td class="fw-semibold">@v.CallSign</td>
                                    <td class="text-center text-success fw-bold">@v.AcceptedCount</td>
                                    <td class="text-center text-danger">@v.RefusedCount</td>
                                    <td class="text-center">
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-success" style="width:@(v.TotalCount > 0 ? (v.AcceptedCount * 100 / v.TotalCount) : 0)%"></div>
                                            <div class="progress-bar bg-danger" style="width:@(v.TotalCount > 0 ? (v.RefusedCount * 100 / v.TotalCount) : 0)%"></div>
                                        </div>
                                        <small class="text-muted">@v.TotalCount</small>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 10 dernières missions -->
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">
            <i class="fa-solid fa-list me-2 text-secondary"></i>10 dernières missions
        </h6>
        <a asp-page="/Missions/Index" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-external-link-alt me-1"></i>Toutes les missions
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Référence</th>
                        <th>Statut</th>
                        <th>Adresse</th>
                        <th>Véhicule</th>
                        <th>Créée</th>
                        <th>Terminée</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in d.RecentMissions)
                    {
                        <tr>
                            <td class="fw-semibold">@m.Reference</td>
                            <td>
                                @{ ViewData["Status"] = m.Status; }
                                @await Html.PartialAsync("_StatusBadge")
                            </td>
                            <td>@m.TargetAddress</td>
                            <td>@(m.AssignedVehicleCallSign ?? "—")</td>
                            <td>@m.CreatedAt.ToLocalTime().ToString("HH:mm")</td>
                            <td>@(m.CompletedAt?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                            <td>
                                <a asp-page="/Missions/Details" asp-route-id="@m.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ===================== ÉVOLUTION TEMPORELLE ===================== -->
<div class="card shadow-sm mt-4">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h6 class="mb-0 fw-semibold">
            <i class="fa-solid fa-chart-line me-2 text-primary"></i>Évolution sur @Model.Days jours
            <small class="text-muted fw-normal ms-2">(@ts.CurrentPeriod.PeriodLabel)</small>
        </h6>
        <!-- Sélecteur de période -->
        <div class="btn-group btn-group-sm" role="group">
            <a asp-page="/Dashboard/Index" asp-route-days="7"
               class="btn @(Model.Days == 7 ? "btn-primary" : "btn-outline-primary")">7j</a>
            <a asp-page="/Dashboard/Index" asp-route-days="14"
               class="btn @(Model.Days == 14 ? "btn-primary" : "btn-outline-primary")">14j</a>
            <a asp-page="/Dashboard/Index" asp-route-days="30"
               class="btn @(Model.Days == 30 ? "btn-primary" : "btn-outline-primary")">30j</a>
        </div>
    </div>
    <div class="card-body">
        <!-- Cartes de comparaison -->
        <div class="row g-3 mb-4">
            <!-- Appels -->
            <div class="col-md-4">
                <div class="card border h-100">
                    <div class="card-body text-center">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">
                            <i class="fa-solid fa-phone me-1"></i>Appels
                        </div>
                        <div class="fs-2 fw-bold text-primary">@ts.CurrentPeriod.TotalCalls</div>
                        <div class="text-muted small">vs @ts.PreviousPeriod.TotalCalls période précédente</div>
                        @if (ts.CurrentPeriod.CallsDeltaPercent.HasValue)
                        {
                            var delta = ts.CurrentPeriod.CallsDeltaPercent.Value;
                            @if (delta > 0)
                            {
                                <span class="badge bg-danger-subtle text-danger mt-1">
                                    <i class="fa-solid fa-arrow-up me-1"></i>@delta.ToString("F1")%
                                </span>
                            }
                            else if (delta < 0)
                            {
                                <span class="badge bg-success-subtle text-success mt-1">
                                    <i class="fa-solid fa-arrow-down me-1"></i>@Math.Abs(delta).ToString("F1")%
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary mt-1">= stable</span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary mt-1">nouveau</span>
                        }
                    </div>
                </div>
            </div>
            <!-- Missions complétées -->
            <div class="col-md-4">
                <div class="card border h-100">
                    <div class="card-body text-center">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">
                            <i class="fa-solid fa-flag-checkered me-1"></i>Missions complétées
                        </div>
                        <div class="fs-2 fw-bold text-success">@ts.CurrentPeriod.CompletedMissions</div>
                        <div class="text-muted small">vs @ts.PreviousPeriod.CompletedMissions période précédente</div>
                        @if (ts.CurrentPeriod.MissionsDeltaPercent.HasValue)
                        {
                            var delta = ts.CurrentPeriod.MissionsDeltaPercent.Value;
                            @if (delta > 0)
                            {
                                <span class="badge bg-success-subtle text-success mt-1">
                                    <i class="fa-solid fa-arrow-up me-1"></i>@delta.ToString("F1")%
                                </span>
                            }
                            else if (delta < 0)
                            {
                                <span class="badge bg-danger-subtle text-danger mt-1">
                                    <i class="fa-solid fa-arrow-down me-1"></i>@Math.Abs(delta).ToString("F1")%
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary mt-1">= stable</span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary mt-1">nouveau</span>
                        }
                    </div>
                </div>
            </div>
            <!-- Temps de réponse moyen -->
            <div class="col-md-4">
                <div class="card border h-100">
                    <div class="card-body text-center">
                        <div class="text-muted small fw-semibold text-uppercase mb-1">
                            <i class="fa-solid fa-stopwatch me-1"></i>Temps de réponse moyen
                        </div>
                        <div class="fs-2 fw-bold text-info">@ts.CurrentPeriod.AverageResponseTimeMinutes.ToString("F1") min</div>
                        <div class="text-muted small">vs @ts.PreviousPeriod.AverageResponseTimeMinutes.ToString("F1") min période préc.</div>
                        @if (ts.CurrentPeriod.ResponseTimeDeltaPercent.HasValue)
                        {
                            var delta = ts.CurrentPeriod.ResponseTimeDeltaPercent.Value;
                            @if (delta > 0)
                            {
                                <span class="badge bg-danger-subtle text-danger mt-1">
                                    <i class="fa-solid fa-arrow-up me-1"></i>@delta.ToString("F1")%
                                </span>
                            }
                            else if (delta < 0)
                            {
                                <span class="badge bg-success-subtle text-success mt-1">
                                    <i class="fa-solid fa-arrow-down me-1"></i>@Math.Abs(delta).ToString("F1")%
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary mt-1">= stable</span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary mt-1">nouveau</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Tableau des jours -->
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th class="text-center">Appels</th>
                        <th class="text-center">Missions</th>
                        <th class="text-center">Complétées</th>
                        <th class="text-center">Tps réponse moy.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in ts.Days.OrderByDescending(x => x.Date))
                    {
                        <tr>
                            <td class="fw-semibold">
                                @day.Date.ToLocalTime().ToString("ddd dd/MM/yyyy",
                                    new System.Globalization.CultureInfo("fr-FR"))
                            </td>
                            <td class="text-center">
                                @if (day.Calls > 0)
                                {
                                    <span class="badge bg-primary">@day.Calls</span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>
                            <td class="text-center">@day.Missions</td>
                            <td class="text-center">
                                @if (day.CompletedMissions > 0)
                                {
                                    <span class="badge bg-success">@day.CompletedMissions</span>
                                }
                                else
                                {
                                    <span class="text-muted">0</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (day.AverageResponseTimeMinutes > 0)
                                {
                                    <span class="text-info fw-semibold">@day.AverageResponseTimeMinutes.ToString("F1") min</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        var ctx = document.getElementById('missionsChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(hoursJson),
                datasets: [{
                    label: 'Missions',
                    data: @Html.Raw(countsJson),
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderColor: 'rgba(13,110,253,1)',
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y + ' mission(s)'
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 },
                        title: { display: true, text: 'Nb missions' }
                    },
                    x: {
                        title: { display: true, text: 'Heure' }
                    }
                }
            }
        });
    })();
    </script>
}
