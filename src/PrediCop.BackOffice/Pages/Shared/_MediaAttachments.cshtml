@using PrediCop.BackOffice.Models
@model List<MediaAttachmentDto>

@{
    var attachments = Model ?? [];
    // Context: parentId (Guid) and parentType ("mission" | "document") injected via ViewData
    var parentType = ViewData["MediaParentType"] as string ?? "mission";
    var parentId = ViewData["MediaParentId"] as Guid? ?? Guid.Empty;
    bool isManager = User.IsInRole("Manager") || User.IsInRole("Admin");
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">
            <i class="fa-solid fa-photo-film me-2 text-danger"></i>Médias / Pièces jointes
            <span class="badge bg-secondary ms-1">@attachments.Count</span>
        </h6>
    </div>
    <div class="card-body p-0">
        @if (attachments.Any())
        {
            <table class="table table-hover align-middle small mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fichier</th>
                        <th>Enregistré le</th>
                        <th>Taille</th>
                        <th>Durée</th>
                        <th>Caméra</th>
                        <th>Envoyé par</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in attachments)
                    {
                        <tr>
                            <td>
                                @if (m.IsVideo)
                                {
                                    <i class="fa-solid fa-film text-danger me-1"></i>
                                }
                                else if (m.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                                {
                                    <i class="fa-solid fa-image text-success me-1"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-file text-secondary me-1"></i>
                                }
                                <span class="text-truncate" style="max-width:200px;display:inline-block;vertical-align:middle;"
                                      title="@m.FileName">@m.FileName</span>
                            </td>
                            <td class="text-nowrap">@m.RecordedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-nowrap text-muted">@m.FileSizeLabel</td>
                            <td class="text-muted">
                                @(m.DurationSeconds.HasValue
                                    ? $"{m.DurationSeconds / 60}:{m.DurationSeconds % 60:D2}"
                                    : "—")
                            </td>
                            <td class="text-muted font-monospace small">@(m.CameraDeviceId ?? "—")</td>
                            <td class="text-muted">@m.CreatedByName</td>
                            <td class="text-end text-nowrap">
                                @if (m.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a href="@Url.Page("/Media/Download", new { id = m.Id })" target="_blank"
                                       class="btn btn-sm btn-outline-success py-0 me-1" title="Voir">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                }
                                <a asp-page="/Media/Download" asp-route-id="@m.Id"
                                   class="btn btn-sm btn-outline-primary py-0" title="Télécharger">
                                    <i class="fa-solid fa-download"></i>
                                </a>
                                @if (isManager)
                                {
                                    <form method="post"
                                          asp-page="@(parentType == "mission" ? "/Missions/Details" : "/Documents/Details")"
                                          asp-route-id="@parentId"
                                          asp-page-handler="DeleteMedia"
                                          class="d-inline ms-1">
                                        <input type="hidden" name="mediaId" value="@m.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger py-0"
                                                onclick="return confirm('Supprimer ce fichier ?')" title="Supprimer">
                                            <i class="fa-solid fa-times"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center text-muted py-3 small">
                <i class="fa-solid fa-photo-film opacity-30 me-1"></i>Aucun média joint.
            </div>
        }
    </div>
</div>
