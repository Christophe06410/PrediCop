<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrediCop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background-color: #f0f2f5; }
        .navbar-brand img { height: 32px; }
        .sidebar { min-height: calc(100vh - 56px); background: #1a2035; }
        .sidebar .nav-link { color: #a0aec0; padding: .5rem 1rem; border-radius: .375rem; margin: 2px 8px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: #2d3a5a; }
        .sidebar .nav-link i { width: 20px; text-align: center; margin-right: 8px; }
        .sidebar .sidebar-heading { color: #4a5568; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; padding: .5rem 1rem; margin-top: .5rem; }
        .main-content { min-height: calc(100vh - 56px); }
        .card { border: none; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
        .badge-status-Pending { background-color: #fd7e14; }
        .badge-status-Proposed { background-color: #6f42c1; }
        .badge-status-Accepted { background-color: #0d6efd; }
        .badge-status-InProgress { background-color: #198754; }
        .badge-status-Completed { background-color: #6c757d; }
        .badge-status-Refused { background-color: #dc3545; }
        .badge-status-Cancelled { background-color: #6c757d; }
        .call-timer-bar { background: #1a2035; color: #fff; padding: .4rem 1rem; font-size: .9rem; }
        .kpi-card .kpi-value { font-size: 2rem; font-weight: 700; }
        .kpi-card .kpi-icon { font-size: 2.5rem; opacity: .15; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-page="/Index">
                <i class="fa-solid fa-shield-halved text-primary me-2"></i>PrediCop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Calls/Receive">
                            <i class="fa-solid fa-phone me-1"></i>Réception appel
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Calls/Index">
                            <i class="fa-solid fa-list me-1"></i>Appels
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Missions/Index">
                            <i class="fa-solid fa-car-side me-1"></i>Missions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Dashboard/Index">
                            <i class="fa-solid fa-gauge me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fa-solid fa-gear me-1"></i>Administration
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-page="/Admin/Vehicles/Index"><i class="fa-solid fa-car me-2"></i>Véhicules</a></li>
                            <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="fa-solid fa-users me-2"></i>Utilisateurs</a></li>
                        </ul>
                    </li>
                    <li class="nav-item ms-2">
                        <span class="navbar-text text-secondary small">
                            <i class="fa-solid fa-circle text-success me-1" style="font-size:.6rem"></i>En ligne
                        </span>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Timer bar partiel si en cours d'appel -->
    @if (ViewData["ActiveCall"] != null)
    {
        @await Html.PartialAsync("_CallTimer")
    }

    <!-- Contenu principal -->
    <main class="container-fluid py-3">
        @RenderBody()
    </main>

    <!-- Pied de page -->
    <footer class="bg-dark text-secondary py-2 mt-auto">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <span class="small"><i class="fa-solid fa-shield-halved me-1"></i>PrediCop &copy; @DateTime.Now.Year</span>
            <span class="small">Back-Office v1.0 &mdash; .NET 10</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
