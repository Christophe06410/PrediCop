<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrediCop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <style>
        body { background-color: #f0f2f5; }
        .navbar-brand img { height: 32px; }
        .sidebar { min-height: calc(100vh - 56px); background: #1a2035; }
        .sidebar .nav-link { color: #a0aec0; padding: .5rem 1rem; border-radius: .375rem; margin: 2px 8px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: #2d3a5a; }
        .sidebar .nav-link i { width: 20px; text-align: center; margin-right: 8px; }
        .sidebar .sidebar-heading { color: #4a5568; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; padding: .5rem 1rem; margin-top: .5rem; }
        .main-content { min-height: calc(100vh - 56px); }
        .card { border: none; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
        .badge-status-Pending { background-color: #fd7e14; }
        .badge-status-Proposed { background-color: #6f42c1; }
        .badge-status-Accepted { background-color: #0d6efd; }
        .badge-status-InProgress { background-color: #198754; }
        .badge-status-Completed { background-color: #6c757d; }
        .badge-status-Refused { background-color: #dc3545; }
        .badge-status-Cancelled { background-color: #6c757d; }
        .call-timer-bar { background: #1a2035; color: #fff; padding: .4rem 1rem; font-size: .9rem; }
        .kpi-card .kpi-value { font-size: 2rem; font-weight: 700; }
        .kpi-card .kpi-icon { font-size: 2.5rem; opacity: .15; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-page="/Index">
                <img src="~/logo.png" alt="PrediCop" style="height:28px;width:28px;object-fit:contain;" />
                PrediCop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Home/Index">
                            <i class="fa-solid fa-house me-1"></i>Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Calls/Receive">
                            <i class="fa-solid fa-phone me-1"></i>Réception appel
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Calls/Index">
                            <i class="fa-solid fa-list me-1"></i>Mains courantes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Missions/Index">
                            <i class="fa-solid fa-car-side me-1"></i>Missions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Crews/Index">
                            <i class="fa-solid fa-users me-1"></i>Équipages
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fa-solid fa-file-contract me-1"></i>Vacations
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-page="/Missions/ShiftReport">
                                    <i class="fa-solid fa-plus me-2 text-primary"></i>Nouveau rapport
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-page="/Missions/ShiftReports">
                                    <i class="fa-solid fa-clock-rotate-left me-2 text-secondary"></i>Historique
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Map/Index">
                            <i class="fa-solid fa-map-location-dot me-1"></i>Carte
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Dashboard/Index">
                            <i class="fa-solid fa-gauge me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fa-solid fa-gear me-1"></i>Administration
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-page="/Admin/Vehicles/Index"><i class="fa-solid fa-car me-2"></i>Véhicules</a></li>
                            <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="fa-solid fa-users me-2"></i>Utilisateurs</a></li>
                            <li><a class="dropdown-item" asp-page="/Admin/Streets/Index"><i class="fa-solid fa-map-location-dot me-2"></i>Rues &amp; scores de risque</a></li>
                            <li><a class="dropdown-item" asp-page="/Admin/GeoZones/Index"><i class="fa-solid fa-draw-polygon me-2"></i>Zones de patrouille</a></li>
                            <li><a class="dropdown-item" asp-page="/Admin/RiskEvents/Index"><i class="fa-solid fa-triangle-exclamation me-2"></i>Événements de risque</a></li>
                            <li><a class="dropdown-item" asp-page="/Admin/Qualifications/Index"><i class="fa-solid fa-id-card me-2"></i>Habilitations agents</a></li>
                            @await Component.InvokeAsync("OptionalModulesMenu")
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-page="/Admin/Subscription/Index"><i class="fa-solid fa-credit-card me-2"></i>Mon abonnement</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Audit/Index"><i class="fa-solid fa-clipboard-list me-2"></i>Journal d'audit</a></li>
                                <li><a class="dropdown-item" asp-page="/Admin/RgpdRequests/Index"><i class="fa-solid fa-shield-halved me-2"></i>Demandes RGPD</a></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Settings"><i class="fa-solid fa-sliders me-2"></i>Paramètres</a></li>
                            }
                        </ul>
                    </li>
                    <li class="nav-item ms-2">
                        <form asp-page="/Search/Index" method="get" class="d-flex">
                            <div class="input-group input-group-sm">
                                <input type="text" name="Q" class="form-control form-control-sm bg-dark border-secondary text-white"
                                       placeholder="Rechercher..." style="width:180px;"
                                       value="@(ViewContext.HttpContext.Request.Query["Q"].ToString())" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm">
                                    <i class="fa-solid fa-magnifying-glass text-white"></i>
                                </button>
                            </div>
                        </form>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-2 dropdown">
                            <a class="nav-link dropdown-toggle text-secondary small" href="#" data-bs-toggle="dropdown">
                                <i class="fa-solid fa-circle text-success me-1" style="font-size:.6rem"></i>
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-page="/Account/ChangePassword">
                                        <i class="fa-solid fa-key me-2"></i>Changer mon mot de passe
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-page="/Account/Logout" method="post" class="d-inline w-100">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i>Se déconnecter
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Timer bar partiel si en cours d'appel -->
    @if (ViewData["ActiveCall"] != null)
    {
        @await Html.PartialAsync("_CallTimer")
    }

    <!-- Contenu principal -->
    <main class="container-fluid py-3">
        @RenderBody()
    </main>

    <!-- Pied de page -->
    <footer class="bg-dark text-secondary py-2 mt-auto">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <span class="small"><i class="fa-solid fa-shield-halved me-1"></i>PrediCop &copy; @DateTime.Now.Year</span>
            <span class="small">
                <a asp-page="/Rgpd/Index" class="text-secondary text-decoration-none me-3">
                    <i class="fa-solid fa-shield-halved me-1"></i>RGPD
                </a>
                Back-Office v1.0 &mdash; .NET 10
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/text-assistant.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <partial name="_TextAssistantModal" />

    <!-- === Modal SOS === -->
    <div class="modal fade" id="sos-alert-modal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-labelledby="sosAlertLabel" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 bg-danger text-white">
                <div class="modal-header border-0 pb-0">
                    <h4 class="modal-title fw-bold" id="sosAlertLabel">
                        <i class="fa-solid fa-siren-on fa-beat me-2"></i>ALERTE SOS
                    </h4>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="fs-3 fw-bold mb-2" id="sos-reference">—</p>
                    <p class="fs-5 mb-4" id="sos-address">—</p>
                    <div class="d-flex gap-3 justify-content-center">
                        <a id="sos-link" href="#" class="btn btn-light btn-lg text-danger fw-bold">
                            <i class="fa-solid fa-eye me-2"></i>Voir l'appel
                        </a>
                        <button type="button" class="btn btn-outline-light btn-lg" data-bs-dismiss="modal">
                            <i class="fa-solid fa-xmark me-2"></i>Fermer
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- === Toast Container (critiques + missions) === -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
        <div id="critique-toast" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="10000">
            <div class="d-flex">
                <div class="toast-body fw-semibold" id="critique-toast-body">
                    <i class="fa-solid fa-fire me-2"></i>APPEL CRITIQUE
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fermer"></button>
            </div>
        </div>
        <div id="mission-completed-toast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="polite" aria-atomic="true" data-bs-delay="5000">
            <div class="d-flex">
                <div class="toast-body fw-semibold" id="mission-completed-toast-body">
                    &#x2705; Mission — TERMINÉE
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fermer"></button>
            </div>
        </div>
        <div id="mission-accepted-toast" class="toast align-items-center text-white bg-primary border-0" role="alert" aria-live="polite" aria-atomic="true" data-bs-delay="5000">
            <div class="d-flex">
                <div class="toast-body fw-semibold" id="mission-accepted-toast-body">
                    &#x1F697; Mission acceptée
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fermer"></button>
            </div>
        </div>
    </div>

    <!-- === SignalR + Alertes priorité === -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
    (function () {
        // ---- Web Audio beeps ----
        function playAlertBeeps(count) {
            try {
                var ctx = new (window.AudioContext || window.webkitAudioContext)();
                for (var i = 0; i < count; i++) {
                    var osc = ctx.createOscillator();
                    var gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.frequency.value = 880;
                    gain.gain.setValueAtTime(0.3, ctx.currentTime + i * 0.4);
                    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.4 + 0.3);
                    osc.start(ctx.currentTime + i * 0.4);
                    osc.stop(ctx.currentTime + i * 0.4 + 0.3);
                }
            } catch (e) { /* AudioContext non disponible */ }
        }

        function showSosModal(data) {
            document.getElementById('sos-reference').textContent = '🚨 ALERTE SOS — ' + (data.reference || '');
            document.getElementById('sos-address').textContent = data.incidentAddress || '';
            document.getElementById('sos-link').href = '/Calls/Details/' + data.id;
            var modal = new bootstrap.Modal(document.getElementById('sos-alert-modal'));
            modal.show();
            playAlertBeeps(3);
        }

        function showCritiqueToast(data) {
            var body = '⚠️ APPEL CRITIQUE — ' + (data.incidentAddress || '');
            document.getElementById('critique-toast-body').textContent = body;
            var toastEl = document.getElementById('critique-toast');
            var toast = bootstrap.Toast.getOrCreateInstance(toastEl);
            toast.show();
        }

        // ---- SignalR connection ----
        var connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/police')
            .withAutomaticReconnect()
            .build();

        connection.on('NewCallReceived', function (data) {
            var priority = data.priority;
            if (priority === 'SOS' || priority === 3) {
                showSosModal(data);
            } else if (priority === 'Critique' || priority === 2) {
                showCritiqueToast(data);
            }
        });

        connection.on('MissionStatusChanged', function (data) {
            if (data.status === 'Completed') {
                var body = '✅ Mission ' + (data.reference || '') + ' — TERMINÉE';
                document.getElementById('mission-completed-toast-body').textContent = body;
                var toastEl = document.getElementById('mission-completed-toast');
                bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 5000 }).show();
            } else if (data.status === 'Accepted') {
                var callSign = (data.vehicleCallSign || data.callSign || '');
                var body2 = '🚗 Mission ' + (data.reference || '') + ' acceptée' + (callSign ? ' par ' + callSign : '');
                document.getElementById('mission-accepted-toast-body').textContent = body2;
                var toastEl2 = document.getElementById('mission-accepted-toast');
                bootstrap.Toast.getOrCreateInstance(toastEl2, { delay: 5000 }).show();
            }
        });

        connection.start().catch(function (err) {
            console.warn('[PrediCop] SignalR connection failed:', err);
        });
    })();
    </script>
</body>
</html>
