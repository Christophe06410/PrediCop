<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrediCop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <style>
        body { background: #f8f9fa; }
        .hero-section { background: linear-gradient(135deg, #1a2035 0%, #2d3a5a 100%); color: #fff; padding: 80px 0; }
        .feature-icon { width: 56px; height: 56px; background: rgba(13,110,253,.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: #0d6efd; }
        .pricing-card { transition: transform .2s; }
        .pricing-card:hover { transform: translateY(-4px); }
        .pricing-card.featured { border: 2px solid #0d6efd !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-page="/Public/Index">
                <img src="~/logo.png" alt="PrediCop" style="height:28px;width:28px;object-fit:contain;" />
                PrediCop
            </a>
            <div class="ms-auto d-flex gap-2 align-items-center">
                <a asp-page="/Public/Pricing" class="btn btn-sm btn-outline-light">Tarifs</a>
                <a asp-page="/Account/Login" class="btn btn-sm btn-light">Se connecter</a>
                <a asp-page="/Public/Signup/Index" class="btn btn-sm btn-primary">S'inscrire</a>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-secondary py-4 mt-5">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="fa-solid fa-shield-halved me-1"></i>PrediCop &copy; @DateTime.Now.Year — Gestion de Police Municipale</span>
            <span class="small">
                <a asp-page="/Public/Pricing" class="text-secondary me-3">Tarifs</a>
                <a href="mailto:contact@predicop.fr" class="text-secondary">Contact</a>
            </span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
