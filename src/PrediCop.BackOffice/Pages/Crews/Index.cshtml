@page
@model PrediCop.BackOffice.Pages.Crews.IndexModel
@{
    ViewData["Title"] = "Équipages en service";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h4 mb-0">
        <i class="fa-solid fa-users me-2 text-primary"></i>
        Équipages en service
        <span class="badge bg-primary ms-2">@Model.Crews.Count</span>
    </h1>
    <div class="d-flex align-items-center gap-3">
        <small class="text-muted">
            <i class="fa-solid fa-clock me-1"></i>Mise à jour à @Model.LoadedAt.ToString("HH:mm:ss")
        </small>
        <a href="/Crews" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-rotate me-1"></i>Actualiser
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ErrorMessage
    </div>
}
else if (Model.Crews.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="fa-solid fa-users-slash fa-3x mb-3 d-block opacity-25"></i>
            <p class="mb-0">Aucun équipage en service actuellement.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th><i class="fa-solid fa-radio me-1"></i>Indicatif</th>
                            <th>Statut</th>
                            <th><i class="fa-solid fa-user-shield me-1"></i>Équipage</th>
                            <th><i class="fa-solid fa-car-side me-1"></i>Mission en cours</th>
                            <th><i class="fa-solid fa-map-pin me-1"></i>Position</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var crew in Model.Crews)
                        {
                            <tr id="crew-row-@crew.VehicleId">
                                <td>
                                    <div class="fw-semibold">@crew.CallSign</div>
                                    <small class="text-muted">@crew.LicensePlate</small>
                                </td>
                                <td>
                                    @{
                                        var (badgeClass, statusLabel) = crew.Status switch
                                        {
                                            "OnMission" => ("bg-danger", "En mission"),
                                            "Busy"      => ("bg-warning text-dark", "Occupé"),
                                            "Available" => ("bg-success", "Disponible"),
                                            _           => ("bg-secondary", crew.Status)
                                        };
                                    }
                                    <span class="badge @badgeClass">@statusLabel</span>
                                </td>
                                <td>
                                    @if (crew.Officers.Count == 0)
                                    {
                                        <span class="text-muted fst-italic">Sans agent</span>
                                    }
                                    else
                                    {
                                        foreach (var officer in crew.Officers)
                                        {
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <span>@officer.FullName</span>
                                                <span class="badge bg-secondary">@officer.BadgeNumber</span>
                                            </div>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (crew.CurrentMission is not null)
                                    {
                                        var m = crew.CurrentMission;
                                        var duration = crew.CurrentMission.AcceptedAt.HasValue
                                            ? (DateTime.UtcNow - crew.CurrentMission.AcceptedAt.Value)
                                            : (TimeSpan?)null;
                                        var durationText = duration.HasValue
                                            ? (duration.Value.TotalHours >= 1
                                                ? $"{(int)duration.Value.TotalHours}h{duration.Value.Minutes:00}"
                                                : $"{duration.Value.Minutes} min")
                                            : "";
                                        var priorityClass = m.Priority switch
                                        {
                                            "Critique" => "bg-danger",
                                            "SOS"      => "bg-danger",
                                            "Urgent"   => "bg-warning text-dark",
                                            _          => "bg-secondary"
                                        };
                                        <div>
                                            <a href="/Missions/Details/@m.MissionId" class="fw-semibold text-decoration-none">@m.Reference</a>
                                            <span class="badge @priorityClass ms-1">@m.Priority</span>
                                            @if (!string.IsNullOrEmpty(durationText))
                                            {
                                                <span class="badge bg-light text-dark ms-1">
                                                    <i class="fa-solid fa-stopwatch me-1"></i>@durationText
                                                </span>
                                            }
                                            <div class="text-muted small">@m.TargetAddress</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (crew.LastLatitude.HasValue && crew.LastLongitude.HasValue)
                                    {
                                        var mapsUrl = $"https://www.google.com/maps?q={crew.LastLatitude:F5},{crew.LastLongitude:F5}";
                                        <a href="@mapsUrl" target="_blank" class="btn btn-outline-secondary btn-sm">
                                            <i class="fa-solid fa-map-location-dot me-1"></i>Voir
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Non disponible</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
    // Auto-refresh toutes les 30 secondes
    setTimeout(function () { location.reload(); }, 30000);

    // SignalR : rechargement si une mission change de statut
    (function () {
        var connection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/police')
            .withAutomaticReconnect()
            .build();

        connection.on('MissionStatusChanged', function (data) {
            // Recharger la page pour refléter le nouveau statut
            location.reload();
        });

        connection.start().catch(function (err) {
            console.warn('[Crews] SignalR connection failed:', err);
        });
    })();
    </script>
}
