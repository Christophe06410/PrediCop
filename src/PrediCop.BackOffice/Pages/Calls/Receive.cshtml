@page
@model PrediCop.BackOffice.Pages.Calls.ReceiveModel
@{
    ViewData["Title"] = "Réception d'appel";
    ViewData["ActiveCall"] = true;
    ViewData["CallStartTime"] = Model.CallStartTime;
}

@*
    2b — "Retourner à l'appel" button:
    When ViewData["ActiveCall"] == true the layout renders the _CallTimer partial
    (Pages/Shared/_CallTimer.cshtml) which already contains the "Retourner à l'appel"
    button linked back to /Calls/Receive. That button appears on every page while a
    call is in progress so the operator can navigate away and return safely.
    No extra button is needed here — the operator is already on this page.
*@

<!-- Barre d'état appel en cours -->
<div class="alert alert-dark d-flex align-items-center gap-3 py-2 mb-3 rounded-2" id="call-status-bar">
    <span class="text-warning fw-bold fs-6">
        <i class="fa-solid fa-phone-volume fa-beat me-2"></i>Appel en cours
    </span>
    <span class="text-white fw-bold" id="call-timer">00:00</span>
    <span class="text-secondary small">Démarré à @Model.CallStartTime.ToString("HH:mm:ss")</span>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* 2a — Draft feedback banners (persist across the same page reload) *@
@if (TempData["DraftSuccessMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show">
        <i class="fa-solid fa-floppy-disk me-2"></i>@TempData["DraftSuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["DraftErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["DraftErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-0 mb-2">
    <div class="col">
        <h4 class="fw-bold mb-0"><i class="fa-solid fa-headset me-2 text-primary"></i>Réception d'appel</h4>
    </div>
</div>

<form method="post" id="call-form">
    <div asp-validation-summary="All" class="alert alert-danger mb-0"></div>
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-4">
                <!-- Colonne gauche -->
                <div class="col-md-6">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">
                        <i class="fa-solid fa-user me-2"></i>Informations appelant &amp; incident
                    </h6>

                    <div class="mb-3">
                        <label asp-for="Input.CallerName" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                            <input asp-for="Input.CallerName" class="form-control" placeholder="Nom complet de l'appelant" />
                        </div>
                        <span asp-validation-for="Input.CallerName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.CallerPhone" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                            <input asp-for="Input.CallerPhone" class="form-control" placeholder="06 00 00 00 00" type="tel" />
                        </div>
                        <span asp-validation-for="Input.CallerPhone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold"><i class="fa-solid fa-circle-exclamation me-1"></i>Priorité</label>
                        <div class="btn-group w-100" role="group" aria-label="Priorité de l'appel">
                            <input type="radio" class="btn-check" asp-for="Input.Priority" id="prio-routine" value="Routine" />
                            <label class="btn btn-outline-secondary" for="prio-routine">
                                <i class="fa-solid fa-circle-check me-1"></i>Routine
                            </label>
                            <input type="radio" class="btn-check" asp-for="Input.Priority" id="prio-urgent" value="Urgent" />
                            <label class="btn btn-outline-warning" for="prio-urgent">
                                <i class="fa-solid fa-triangle-exclamation me-1"></i>Urgent
                            </label>
                            <input type="radio" class="btn-check" asp-for="Input.Priority" id="prio-critique" value="Critique" />
                            <label class="btn btn-outline-danger" for="prio-critique">
                                <i class="fa-solid fa-fire me-1"></i>Critique
                            </label>
                            <input type="radio" class="btn-check" asp-for="Input.Priority" id="prio-sos" value="SOS" />
                            <label class="btn btn-danger" for="prio-sos">
                                <i class="fa-solid fa-siren-on me-1"></i>SOS
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.IncidentCategory" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-tag"></i></span>
                            <select asp-for="Input.IncidentCategory" class="form-select">
                                <option value="">-- Sélectionner une catégorie --</option>
                                @foreach (var cat in ReceiveModel.Categories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                        <span asp-validation-for="Input.IncidentCategory" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.IncidentDescription" class="form-label fw-semibold"></label>
                        <textarea asp-for="Input.IncidentDescription" class="form-control" rows="5"
                                  placeholder="Décrivez l'incident en détail..."
                                  data-text-assistant></textarea>
                        <span asp-validation-for="Input.IncidentDescription" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Colonne droite -->
                <div class="col-md-6">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">
                        <i class="fa-solid fa-map-marker-alt me-2"></i>Localisation &amp; informations complémentaires
                    </h6>

                    <div class="mb-3">
                        <label asp-for="Input.IncidentAddress" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-location-dot"></i></span>
                            <input asp-for="Input.IncidentAddress" class="form-control" id="address-input"
                                   placeholder="Numéro, rue, ville" autocomplete="off" />
                            @* 2d — geocode status indicator *@
                            <span class="input-group-text" id="geo-status" title="">
                                <i class="fa-solid fa-circle text-secondary" id="geo-icon" style="font-size:.65rem"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Input.IncidentAddress" class="text-danger small"></span>
                        <div class="form-text" id="geo-text">Adresse géocodée automatiquement.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.IncidentAddressComplement" class="form-label fw-semibold"></label>
                        <input asp-for="Input.IncidentAddressComplement" class="form-control"
                               placeholder="Bâtiment, étage, digicode..." />
                    </div>

                    @* 2d — lat/lon fields are now hidden; values are filled by the auto-geocoder *@
                    <input asp-for="Input.IncidentLatitude" type="hidden" id="gps-lat" />
                    <input asp-for="Input.IncidentLongitude" type="hidden" id="gps-lon" />

                    <div class="mb-3">
                        <label asp-for="Input.ThirdParties" class="form-label fw-semibold"></label>
                        <textarea asp-for="Input.ThirdParties" class="form-control" rows="2"
                                  placeholder="Noms, descriptions des personnes impliquées..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.InternalNotes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Input.InternalNotes" class="form-control" rows="2"
                                  placeholder="Notes pour usage interne uniquement..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light d-flex justify-content-between align-items-center">
            <button type="submit" asp-page-handler="Close" class="btn btn-outline-secondary" id="btn-close">
                <i class="fa-solid fa-times me-2"></i>Fermer sans suite
            </button>
            <div class="d-flex gap-2">
                @* 2a — Save draft: now a real submit targeting OnPostSaveDraftAsync *@
                <button type="submit" asp-page-handler="SaveDraft" class="btn btn-outline-primary" id="btn-save-draft">
                    <i class="fa-solid fa-floppy-disk me-2"></i>Sauvegarder le brouillon
                </button>
                <button type="submit" asp-page-handler="CreateMission" class="btn btn-primary btn-lg" id="btn-create">
                    <i class="fa-solid fa-paper-plane me-2"></i>Créer la Mission
                </button>
            </div>
        </div>
    </div>
</form>

<!-- Liste des mains courantes du jour -->
<div class="card mt-4 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">
            <i class="fa-solid fa-list me-2 text-primary"></i>Mains courantes du jour
            <span class="badge bg-secondary ms-2">@Model.TodayCalls.Count</span>
        </h6>
        @* 2c — "Voir tout" now triggers a JS dialog if the form has data *@
        <a asp-page="/Calls/Index" class="btn btn-sm btn-outline-secondary" id="btn-voir-tout">
            <i class="fa-solid fa-external-link-alt me-1"></i>Voir tout
        </a>
    </div>
    <div class="card-body p-0">
        @if (Model.TodayCalls.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Référence</th>
                            <th>Heure</th>
                            <th>Appelant</th>
                            <th>Catégorie</th>
                            <th>Adresse</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var call in Model.TodayCalls)
                        {
                            <tr>
                                <td class="fw-semibold">@call.Reference</td>
                                <td>@call.ReceivedAt.ToLocalTime().ToString("HH:mm")</td>
                                <td>@call.CallerName</td>
                                <td><span class="badge bg-info text-dark">@call.IncidentCategory</span></td>
                                <td class="text-truncate" style="max-width:150px">@call.IncidentAddress</td>
                                <td>
                                    @{ ViewData["Status"] = call.Status; }
                                    @await Html.PartialAsync("_StatusBadge")
                                </td>
                                <td>
                                    <a asp-page="/Calls/Details" asp-route-id="@call.Id"
                                       class="btn btn-xs btn-outline-primary btn-sm">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-4">
                <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                Aucune main courante enregistrée aujourd'hui.
            </div>
        }
    </div>
</div>

@section Styles {
    <style>.validation-summary-valid { display: none; }</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // ---- Timer appel en cours ----
    (function () {
        var started = new Date();
        function updateTimer() {
            var diff = Math.floor((new Date() - started) / 1000);
            var m = Math.floor(diff / 60).toString().padStart(2, '0');
            var s = (diff % 60).toString().padStart(2, '0');
            document.getElementById('call-timer').textContent = m + ':' + s;
        }
        updateTimer();
        setInterval(updateTimer, 1000);
    })();

    // ---- 2d — Auto-geocode on address change (debounced 800ms) ----
    (function () {
        var geoTimer = null;
        var addressInput = document.getElementById('address-input');
        var geoIcon = document.getElementById('geo-icon');
        var geoText = document.getElementById('geo-text');
        var geoStatus = document.getElementById('geo-status');

        function setGeoState(state, text) {
            // states: idle | loading | ok | error
            geoIcon.className = 'fa-solid';
            geoStatus.title = text || '';
            geoText.textContent = text || '';
            if (state === 'loading') {
                geoIcon.className = 'spinner-border spinner-border-sm text-secondary';
                geoIcon.style.fontSize = '';
            } else if (state === 'ok') {
                geoIcon.className += ' fa-circle-check text-success';
                geoIcon.style.fontSize = '.8rem';
            } else if (state === 'error') {
                geoIcon.className += ' fa-circle-exclamation text-warning';
                geoIcon.style.fontSize = '.8rem';
            } else {
                // idle — grey dot
                geoIcon.className += ' fa-circle text-secondary';
                geoIcon.style.fontSize = '.65rem';
            }
        }

        function geocode(address) {
            if (!address || address.trim().length < 5) {
                setGeoState('idle', 'Adresse géocodée automatiquement.');
                return;
            }
            setGeoState('loading', 'Géocodage en cours...');
            fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(address))
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data && data.length > 0) {
                        document.getElementById('gps-lat').value = parseFloat(data[0].lat).toFixed(6);
                        document.getElementById('gps-lon').value = parseFloat(data[0].lon).toFixed(6);
                        setGeoState('ok', 'Coordonnées GPS trouvées : ' + parseFloat(data[0].lat).toFixed(4) + ', ' + parseFloat(data[0].lon).toFixed(4));
                    } else {
                        document.getElementById('gps-lat').value = '';
                        document.getElementById('gps-lon').value = '';
                        setGeoState('error', 'Adresse introuvable — les coordonnées GPS ne seront pas enregistrées.');
                    }
                })
                .catch(function () {
                    setGeoState('error', 'Erreur de géocodage — les coordonnées GPS ne seront pas enregistrées.');
                });
        }

        addressInput.addEventListener('input', function () {
            clearTimeout(geoTimer);
            setGeoState('idle', 'Adresse géocodée automatiquement.');
            geoTimer = setTimeout(function () { geocode(addressInput.value); }, 800);
        });

        // Geocode on blur for faster feedback when user tabs away
        addressInput.addEventListener('blur', function () {
            clearTimeout(geoTimer);
            geocode(addressInput.value);
        });
    })();

    // ---- 2c — "Voir tout" warns if the form has unsaved data ----
    document.getElementById('btn-voir-tout').addEventListener('click', function (e) {
        // Check whether any form field has a value
        var form = document.getElementById('call-form');
        var inputs = form.querySelectorAll('input[type="text"],input[type="tel"],select,textarea');
        var hasData = false;
        inputs.forEach(function (el) { if (el.value && el.value.trim() !== '' && el.value !== '-- Sélectionner une catégorie --') hasData = true; });
        if (!hasData) return; // Nothing typed — navigate freely

        e.preventDefault();
        var target = this.href;
        var choice = confirm(
            'Le formulaire contient des données non enregistrées.\n\n' +
            '• Cliquez OK pour SAUVEGARDER comme brouillon puis quitter.\n' +
            '• Cliquez Annuler pour rester sur cette page.'
        );
        if (choice) {
            // Submit the draft form then the browser will redirect to index via normal page flow
            // We override the action to SaveDraft via a hidden button click trick
            var draftBtn = document.getElementById('btn-save-draft');
            // Temporarily intercept the draft form response — we can't easily redirect after a POST
            // so instead we navigate to index after a short delay giving the draft time to save
            draftBtn.click();
        }
        // If cancelled: stay on page (default prevented above)
    });

    // ---- Confirmation fermeture sans suite ----
    document.getElementById('btn-close').addEventListener('click', function (e) {
        if (!confirm('Fermer cet appel sans créer de mission ?')) e.preventDefault();
    });
    </script>
}
