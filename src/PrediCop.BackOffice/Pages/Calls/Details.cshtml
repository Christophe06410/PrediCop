@page "{id:guid}"
@model PrediCop.BackOffice.Pages.Calls.DetailsModel
@{
    ViewData["Title"] = $"Appel {Model.Call?.Reference}";
    var call = Model.Call!;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Calls/Index">Appels</a></li>
            <li class="breadcrumb-item active">@call.Reference</li>
        </ol>
    </nav>
    <a asp-page="/Calls/Index" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
</div>

<div class="row g-3">
    <!-- Informations de l'appel -->
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-phone me-2 text-primary"></i>Détails de l'appel
                </h6>
                @{ ViewData["Status"] = call.Status; }
                @await Html.PartialAsync("_StatusBadge")
            </div>
            <div class="card-body">
                <dl class="row g-1 mb-0">
                    <dt class="col-sm-4 text-muted">Référence</dt>
                    <dd class="col-sm-8 fw-semibold">@call.Reference</dd>

                    <dt class="col-sm-4 text-muted">Reçu le</dt>
                    <dd class="col-sm-8">@call.ReceivedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</dd>

                    <dt class="col-sm-4 text-muted">Opérateur</dt>
                    <dd class="col-sm-8">@call.OperatorName</dd>

                    <dt class="col-sm-4 text-muted">Appelant</dt>
                    <dd class="col-sm-8 fw-semibold">@call.CallerName</dd>

                    <dt class="col-sm-4 text-muted">Téléphone</dt>
                    <dd class="col-sm-8">
                        <a href="tel:@call.CallerPhone">@call.CallerPhone</a>
                    </dd>

                    <dt class="col-sm-4 text-muted">Catégorie</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info text-dark">@call.IncidentCategory</span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Localisation -->
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-map-marker-alt me-2 text-danger"></i>Localisation de l'incident
                </h6>
            </div>
            <div class="card-body">
                <dl class="row g-1 mb-3">
                    <dt class="col-sm-4 text-muted">Adresse</dt>
                    <dd class="col-sm-8 fw-semibold">@call.IncidentAddress</dd>

                    @if (!string.IsNullOrEmpty(call.IncidentAddressComplement))
                    {
                        <dt class="col-sm-4 text-muted">Complément</dt>
                        <dd class="col-sm-8">@call.IncidentAddressComplement</dd>
                    }

                    @if (call.IncidentLatitude.HasValue && call.IncidentLongitude.HasValue)
                    {
                        <dt class="col-sm-4 text-muted">GPS</dt>
                        <dd class="col-sm-8 font-monospace">
                            @call.IncidentLatitude.Value.ToString("F6"), @call.IncidentLongitude.Value.ToString("F6")
                        </dd>
                    }
                </dl>

                @if (call.IncidentLatitude.HasValue && call.IncidentLongitude.HasValue)
                {
                    <div id="map-detail" style="height:180px; border-radius:.5rem;"></div>
                }
            </div>
        </div>
    </div>

    <!-- Description -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-file-lines me-2 text-warning"></i>Description &amp; notes
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small text-muted fw-semibold">Description de l'incident</label>
                        <p class="mb-0">@call.IncidentDescription</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted fw-semibold">Tierces personnes</label>
                        <p class="mb-0 @(string.IsNullOrEmpty(call.ThirdParties) ? "text-muted fst-italic" : "")">
                            @(string.IsNullOrEmpty(call.ThirdParties) ? "Aucune" : call.ThirdParties)
                        </p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted fw-semibold">Notes internes</label>
                        <p class="mb-0 @(string.IsNullOrEmpty(call.InternalNotes) ? "text-muted fst-italic" : "text-danger")">
                            @(string.IsNullOrEmpty(call.InternalNotes) ? "Aucune" : call.InternalNotes)
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Missions associées -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-car-side me-2 text-success"></i>Missions associées
                    <span class="badge bg-secondary ms-2">@call.Missions.Count</span>
                </h6>
            </div>
            <div class="card-body p-0">
                @if (call.Missions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Référence</th>
                                    <th>Statut</th>
                                    <th>Adresse cible</th>
                                    <th>Véhicule assigné</th>
                                    <th>Créée le</th>
                                    <th>Acceptée le</th>
                                    <th>Terminée le</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mission in call.Missions)
                                {
                                    <tr>
                                        <td class="fw-semibold">@mission.Reference</td>
                                        <td>
                                            @{ ViewData["Status"] = mission.Status; }
                                            @await Html.PartialAsync("_StatusBadge")
                                        </td>
                                        <td>@mission.TargetAddress</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(mission.AssignedVehicleCallSign))
                                            {
                                                <span class="badge bg-dark">@mission.AssignedVehicleCallSign</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>@mission.CreatedAt.ToLocalTime().ToString("HH:mm")</td>
                                        <td>@(mission.AcceptedAt?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                                        <td>@(mission.CompletedAt?.ToLocalTime().ToString("HH:mm") ?? "—")</td>
                                        <td>
                                            <a asp-page="/Missions/Details" asp-route-id="@mission.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fa-solid fa-inbox me-2"></i>Aucune mission associée à cet appel.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (call.IncidentLatitude.HasValue && call.IncidentLongitude.HasValue)
    {
        <script>
        var map = L.map('map-detail').setView([@call.IncidentLatitude, @call.IncidentLongitude], 16);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);
        L.marker([@call.IncidentLatitude, @call.IncidentLongitude])
            .addTo(map)
            .bindPopup('@Html.Raw(call.IncidentAddress.Replace("'", "\\'"))');
        </script>
    }
}
