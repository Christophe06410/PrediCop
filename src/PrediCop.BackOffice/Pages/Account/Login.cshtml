@page
@model PrediCop.BackOffice.Pages.Account.LoginModel
@{
    Layout = "~/Pages/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Connexion";
}

<div class="login-card">
    <div class="login-header">
        <img src="~/favicon.png" alt="PrediCop" style="height:80px;width:80px;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.4);" />
        <h4 class="text-white mt-3 mb-1 fw-bold">PrediCop</h4>
        <p class="text-secondary mb-0 small">Back-Office — Police Municipale</p>
    </div>

    <div class="p-4">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="alert alert-warning py-2 small mb-3 d-flex align-items-center justify-content-between">
                <span><i class="fa-solid fa-triangle-exclamation me-2"></i>Session expirée. Reconnectez-vous.</span>
                <a asp-page="/Account/Logout" class="btn btn-sm btn-outline-warning ms-2">Se déconnecter</a>
            </div>
        }
        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger py-2 small mb-3">
                <div><i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ErrorMessage</div>
                @if (!string.IsNullOrWhiteSpace(Model.ErrorDetails))
                {
                    <div class="mt-1 text-break"><small>@Model.ErrorDetails</small></div>
                }
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold small text-muted text-uppercase" style="letter-spacing:.05em">Adresse email</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0">
                        <i class="fa-solid fa-envelope text-muted"></i>
                    </span>
                    <input asp-for="Email" type="email" class="form-control border-start-0 ps-1"
                           placeholder="agent@police-municipale.fr" autofocus autocomplete="email" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold small text-muted text-uppercase" style="letter-spacing:.05em">Mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0">
                        <i class="fa-solid fa-lock text-muted"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 ps-1"
                           placeholder="••••••••" autocomplete="current-password" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold small text-muted text-uppercase" style="letter-spacing:.05em">Ville</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0">
                        <i class="fa-solid fa-city text-muted"></i>
                    </span>
                    @if (Model.Tenants.Count == 0)
                    {
                        <input asp-for="CitySlug" type="text" class="form-control border-start-0 ps-1"
                               placeholder="Identifiant de la ville (ex: toulouse)" />
                    }
                    else
                    {
                        <select asp-for="CitySlug" class="form-select border-start-0">
                            <option value="">-- Sélectionnez votre ville --</option>
                            @foreach (var tenant in Model.Tenants)
                            {
                                <option value="@tenant.Slug">@tenant.Name</option>
                            }
                        </select>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Se connecter
            </button>
        </form>
    </div>

    <div class="text-center pb-3 text-muted" style="font-size:.78rem">
        <i class="fa-solid fa-shield-halved me-1"></i>PrediCop &copy; @DateTime.Now.Year — v1.0
    </div>
</div>
