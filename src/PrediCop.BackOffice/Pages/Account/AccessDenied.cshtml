@page
@model PrediCop.BackOffice.Pages.Account.AccessDeniedModel
@{
    Layout = "~/Pages/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Accès refusé";
}

<div class="login-card text-center p-5">
    <i class="fa-solid fa-ban text-danger" style="font-size:3rem"></i>
    <h4 class="mt-3 fw-bold">Accès refusé</h4>
    <p class="text-muted">Vous n'avez pas les droits nécessaires pour accéder à cette page.</p>
    <a asp-page="/Index" class="btn btn-primary mt-2">
        <i class="fa-solid fa-house me-2"></i>Retour à l'accueil
    </a>
</div>
