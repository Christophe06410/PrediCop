@page "{id:guid}"
@model PrediCop.BackOffice.Pages.Documents.PrintModel
@{
    Layout = "_PrintLayout";
    var doc = Model.Document!;
    var frCulture = System.Globalization.CultureInfo.GetCultureInfo("fr-FR");
    ViewData["Title"] = $"Document {doc.Reference}";

    string TypeLabel(string t) => t switch
    {
        "MainCourante" => "MAIN COURANTE",
        "Plainte"      => "PLAINTE",
        _              => t.ToUpperInvariant()
    };

    string StatusLabel(string s) => s switch
    {
        "Brouillon"     => "Brouillon",
        "Finalise"      => "Finalisé",
        "EnvoyeParquet" => "Envoyé au Parquet",
        "EnvoyeJuge"    => "Envoyé au Juge",
        "Archive"       => "Archivé",
        _               => s
    };

    string EntryLabel(string t) => t switch
    {
        "Evenement"   => "Événement",
        "Explication" => "Explication",
        "Temoignage"  => "Témoignage",
        "Note"        => "Note",
        _             => t
    };

    var sortedEntries = doc.Entries.OrderBy(e => e.OccurredAt).ToList();
    var now = DateTime.Now;
}

<style>
    /* ===== Styles généraux ===== */
    .doc-header {
        border-bottom: 3px solid #000;
        padding-bottom: 10px;
        margin-bottom: 18px;
    }

    .doc-header .logo-area {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .doc-header .logo-area img {
        height: 52px;
        width: 52px;
        border-radius: 8px;
    }

    .doc-header .org-name {
        font-size: 13pt;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .doc-header .org-sub {
        font-size: 9pt;
        color: #444;
    }

    .doc-header .ref-area {
        text-align: right;
    }

    .doc-header .ref-area .ref-label {
        font-size: 8pt;
        text-transform: uppercase;
        color: #555;
        letter-spacing: .06em;
    }

    .doc-header .ref-area .ref-number {
        font-size: 14pt;
        font-weight: 700;
        font-family: 'Courier New', monospace;
    }

    .doc-header .ref-area .ref-date {
        font-size: 9pt;
        color: #444;
    }

    /* Bandeau statut / type */
    .status-banner {
        background: #f0f0f0;
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 8px 14px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .status-banner .type-badge {
        font-size: 11pt;
        font-weight: 700;
        letter-spacing: .04em;
        padding: 2px 10px;
        border: 2px solid #000;
        border-radius: 3px;
    }

    .status-banner .type-badge.plainte {
        border-color: #c00;
        color: #c00;
    }

    .status-banner .sep {
        color: #888;
    }

    /* Section informations */
    .info-section {
        margin-bottom: 18px;
    }

    .info-section .section-title {
        font-size: 9pt;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        border-bottom: 1px solid #999;
        padding-bottom: 3px;
        margin-bottom: 8px;
        color: #333;
    }

    .info-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10pt;
    }

    .info-table td {
        padding: 3px 6px;
        vertical-align: top;
    }

    .info-table td:first-child {
        font-weight: 600;
        color: #444;
        white-space: nowrap;
        width: 35%;
    }

    /* Timeline / Chronologie */
    .timeline-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10pt;
    }

    .timeline-table thead tr th {
        background: #1a2035;
        color: #fff;
        font-size: 9pt;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        padding: 5px 8px;
        border: 1px solid #1a2035;
    }

    .timeline-table tbody tr td {
        padding: 6px 8px;
        border: 1px solid #ccc;
        vertical-align: top;
    }

    .timeline-table tbody tr:nth-child(even) td {
        background: #f9f9f9;
    }

    .entry-type-badge {
        display: inline-block;
        font-size: 8pt;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 3px;
        border: 1px solid #999;
        background: #eee;
        white-space: nowrap;
    }

    .entry-type-badge.evenement {
        border-color: #c00;
        background: #fff0f0;
        color: #c00;
    }

    .entry-content {
        white-space: pre-wrap;
        margin: 0;
        font-size: 10pt;
        line-height: 1.5;
    }

    .entry-content.evenement {
        font-weight: 700;
        color: #c00;
    }

    /* Pied de page */
    .doc-footer {
        border-top: 2px solid #000;
        margin-top: 24px;
        padding-top: 10px;
        font-size: 8.5pt;
        color: #444;
    }

    .signature-block {
        margin-top: 28px;
        padding: 16px;
        border: 1px solid #aaa;
        border-radius: 4px;
    }

    .signature-block .sig-title {
        font-size: 9pt;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 4px;
        color: #333;
    }

    .signature-line {
        border-bottom: 1px solid #333;
        height: 50px;
        margin: 8px 0 4px 0;
    }

    .signature-block .sig-label {
        font-size: 8pt;
        color: #666;
    }

    @@media print {
        .doc-header .logo-area img {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }

        .timeline-table thead tr th {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }

        .entry-content.evenement {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }

        .entry-type-badge.evenement {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }

        .status-banner.plainte .type-badge {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }
    }
</style>

<!-- ========== EN-TÊTE OFFICIEL ========== -->
<div class="doc-header">
    <div class="d-flex justify-content-between align-items-start">
        <div class="logo-area">
            <img src="~/favicon.png" alt="PrediCop" />
            <div>
                <div class="org-name">Police Municipale</div>
                <div class="org-sub">Système PrediCop — Gestion des interventions</div>
            </div>
        </div>
        <div class="ref-area">
            <div class="ref-label">Référence document</div>
            <div class="ref-number">@doc.Reference</div>
            <div class="ref-date">Édité le @now.ToString("dd MMMM yyyy", frCulture) à @now.ToString("HH:mm", frCulture)</div>
        </div>
    </div>
</div>

<!-- ========== TITRE ========== -->
<h2 class="fw-bold mb-2" style="font-size:14pt;">@doc.Title</h2>

<!-- ========== BANDEAU TYPE / STATUT ========== -->
<div class="status-banner @(doc.Type == "Plainte" ? "plainte" : "")">
    <span class="type-badge @(doc.Type == "Plainte" ? "plainte" : "")">
        @TypeLabel(doc.Type)
    </span>
    <span class="sep">|</span>
    <span>
        <strong>Statut :</strong> @StatusLabel(doc.Status)
    </span>
    <span class="sep">|</span>
    <span>
        <strong>Mission liée :</strong> @doc.MissionReference
    </span>
</div>

<!-- ========== INFORMATIONS GÉNÉRALES ========== -->
<div class="info-section">
    <div class="section-title">Informations générales</div>
    <table class="info-table">
        <tr>
            <td>Créé par :</td>
            <td>@doc.CreatedByName</td>
        </tr>
        <tr>
            <td>Date de création :</td>
            <td>@doc.CreatedAt.ToLocalTime().ToString("dddd dd MMMM yyyy à HH:mm", frCulture)</td>
        </tr>
        <tr>
            <td>Dernière mise à jour :</td>
            <td>@doc.UpdatedAt.ToLocalTime().ToString("dddd dd MMMM yyyy à HH:mm", frCulture)</td>
        </tr>
        <tr>
            <td>Nombre d'entrées :</td>
            <td>@doc.Entries.Count</td>
        </tr>
    </table>
</div>

<!-- ========== CHRONOLOGIE DES FAITS ========== -->
<div class="info-section">
    <div class="section-title">Chronologie des faits</div>

    @if (sortedEntries.Any())
    {
        <table class="timeline-table">
            <thead>
                <tr>
                    <th style="width:15%;">Date / Heure</th>
                    <th style="width:13%;">Type</th>
                    <th>Contenu</th>
                    <th style="width:16%;">Auteur</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in sortedEntries)
                {
                    bool isEvent = entry.Type == "Evenement";
                    <tr>
                        <td style="white-space:nowrap;font-size:9.5pt;">
                            @entry.OccurredAt.ToLocalTime().ToString("dd/MM/yyyy", frCulture)<br />
                            <span style="color:#555;">@entry.OccurredAt.ToLocalTime().ToString("HH:mm", frCulture)</span>
                        </td>
                        <td>
                            <span class="entry-type-badge @(isEvent ? "evenement" : "")">
                                @EntryLabel(entry.Type)
                            </span>
                        </td>
                        <td>
                            <p class="entry-content @(isEvent ? "evenement" : "")">@entry.Content</p>
                        </td>
                        <td style="font-size:9.5pt;">@entry.CreatedByName</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted fst-italic" style="font-size:10pt;">Aucune entrée enregistrée pour ce document.</p>
    }
</div>

<!-- ========== SIGNATURE ========== -->
<div class="signature-block">
    <div class="sig-title">Visa du responsable</div>
    <div class="row">
        <div class="col-6">
            <div class="sig-label">Nom et prénom :</div>
            <div class="signature-line"></div>
        </div>
        <div class="col-6">
            <div class="sig-label">Signature :</div>
            <div class="signature-line"></div>
        </div>
    </div>
    <div class="sig-label mt-2">Date : _____ / _____ / _________</div>
</div>

<!-- ========== PIED DE PAGE ========== -->
<div class="doc-footer">
    <div class="d-flex justify-content-between">
        <span>Document généré le @now.ToString("dd/MM/yyyy à HH:mm", frCulture) — Confidentiel — Usage interne</span>
        <span>@doc.Reference</span>
    </div>
</div>
