@page "{id:guid?}"
@model PrediCop.BackOffice.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Modifier l'utilisateur" : "Nouvel utilisateur";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Admin/Users/Index">Utilisateurs</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>
    <a asp-page="/Admin/Users/Index" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-user me-2 text-primary"></i>@ViewData["Title"]
                </h6>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Input.Id" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.FirstName" class="form-label fw-semibold"></label>
                            <input asp-for="Input.FirstName" class="form-control" placeholder="Prénom" />
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.LastName" class="form-label fw-semibold"></label>
                            <input asp-for="Input.LastName" class="form-control" placeholder="Nom de famille" />
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                                <input asp-for="Input.Email" class="form-control" type="email"
                                       placeholder="agent@police-municipale.fr" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Input.BadgeNumber" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-id-badge"></i></span>
                                <input asp-for="Input.BadgeNumber" class="form-control text-uppercase"
                                       placeholder="PM-0001" />
                            </div>
                            <span asp-validation-for="Input.BadgeNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.Role" class="form-label fw-semibold"></label>
                            <select asp-for="Input.Role" class="form-select">
                                @foreach (var r in EditModel.Roles)
                                {
                                    <option value="@r">@r</option>
                                }
                            </select>
                            <span asp-validation-for="Input.Role" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="Input.IsActive" class="form-check-label fw-semibold"></label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-3" />

                    @if (!Model.IsEdit)
                    {
                        <h6 class="fw-semibold mb-3"><i class="fa-solid fa-key me-2 text-warning"></i>Mot de passe initial <span class="text-danger">*</span></h6>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                    <input asp-for="Input.Password" type="password" class="form-control"
                                           placeholder="Min. 8 caractères" autocomplete="new-password" />
                                </div>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control"
                                           placeholder="Répétez le mot de passe" autocomplete="new-password" />
                                </div>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>
                        <hr class="my-3" />
                    }
                    else
                    {
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="fw-semibold mb-0"><i class="fa-solid fa-key me-2 text-warning"></i>Réinitialiser le mot de passe</h6>
                                <button type="button" class="btn btn-sm btn-outline-warning"
                                        onclick="document.getElementById('passwordSection').classList.toggle('d-none')">
                                    <i class="fa-solid fa-pen me-1"></i>Changer le mot de passe
                                </button>
                            </div>
                            <div id="passwordSection" class="d-none">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                            <input asp-for="Input.Password" type="password" class="form-control"
                                                   placeholder="Nouveau mot de passe" autocomplete="new-password" />
                                        </div>
                                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold"></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                            <input asp-for="Input.ConfirmPassword" type="password" class="form-control"
                                                   placeholder="Répétez le mot de passe" autocomplete="new-password" />
                                        </div>
                                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="text-muted small mt-1">
                                    Laissez vide pour conserver le mot de passe actuel.
                                </div>
                            </div>
                        </div>
                        <hr class="my-3" />
                    }

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-page="/Admin/Users/Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-times me-2"></i>Annuler
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Enregistrer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
