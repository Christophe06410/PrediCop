@page "{id:guid?}"
@model PrediCop.BackOffice.Pages.Admin.Vehicles.EditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Modifier le véhicule" : "Nouveau véhicule";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Admin/Vehicles/Index">Véhicules</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>
    <a asp-page="/Admin/Vehicles/Index" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-car me-2 text-primary"></i>@ViewData["Title"]
                </h6>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Input.Id" />

                    <div class="mb-3">
                        <label asp-for="Input.CallSign" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-radio"></i></span>
                            <input asp-for="Input.CallSign" class="form-control" placeholder="Ex: PM-01" />
                        </div>
                        <span asp-validation-for="Input.CallSign" class="text-danger small"></span>
                        <div class="form-text">Indicatif radio utilisé par les agents.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.LicensePlate" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-id-card"></i></span>
                            <input asp-for="Input.LicensePlate" class="form-control text-uppercase"
                                   placeholder="AA-000-BB" />
                        </div>
                        <span asp-validation-for="Input.LicensePlate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Status" class="form-label fw-semibold"></label>
                        <select asp-for="Input.Status" class="form-select">
                            @foreach (var s in EditModel.VehicleStatuses)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                        <span asp-validation-for="Input.Status" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.BeaconUuid" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-brands fa-bluetooth-b"></i></span>
                            <input asp-for="Input.BeaconUuid" class="form-control"
                                   placeholder="Ex: 12345678-1234-1234-1234-123456789012" />
                        </div>
                        <span asp-validation-for="Input.BeaconUuid" class="text-danger small"></span>
                        <div class="form-text">UUID du beacon BLE installé dans le véhicule (optionnel). Utilisé pour la détection automatique depuis l'application mobile.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.AssignedGeoZoneId" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-solid fa-draw-polygon"></i></span>
                            <select asp-for="Input.AssignedGeoZoneId" class="form-select">
                                <option value="">— Aucune zone assignée —</option>
                                @foreach (var zone in Model.GeoZones)
                                {
                                    <option value="@zone.Id" style="border-left: 4px solid @zone.Color;">
                                        @zone.Name@(zone.IsActive ? "" : " (inactive)")
                                    </option>
                                }
                            </select>
                        </div>
                        <span asp-validation-for="Input.AssignedGeoZoneId" class="text-danger small"></span>
                        <div class="form-text">Zone de patrouille utilisée pour le géofencing. Une alerte est envoyée si le véhicule sort de cette zone.</div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-page="/Admin/Vehicles/Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-times me-2"></i>Annuler
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Enregistrer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
