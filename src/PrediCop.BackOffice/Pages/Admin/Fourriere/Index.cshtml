@page
@model PrediCop.BackOffice.Pages.Admin.Fourriere.IndexModel
@using PrediCop.Core.Enums
@{
    ViewData["Title"] = "Gestion de la fourrière";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="fa-solid fa-warehouse me-2 text-primary"></i>Gestion de la fourrière
    </h4>
    <button class="btn btn-primary btn-sm" disabled title="Fonctionnalité à venir">
        <i class="fa-solid fa-plus me-1"></i>Nouveau enlèvement
    </button>
</div>

@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-1"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-exclamation me-1"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- KPIs -->
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 flex-shrink-0">
                    <i class="fa-solid fa-warehouse text-primary fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">En fourrière</div>
                    <div class="fw-bold fs-4">@(Model.Stats?.TotalInStorage ?? 0)</div>
                    <span class="badge bg-primary">InStorage</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 flex-shrink-0">
                    <i class="fa-solid fa-circle-check text-success fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">Restitués</div>
                    <div class="fw-bold fs-4">@(Model.Stats?.TotalReleased ?? 0)</div>
                    <span class="badge bg-success">Released</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-secondary bg-opacity-10 p-3 flex-shrink-0">
                    <i class="fa-solid fa-trash text-secondary fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">Détruits</div>
                    <div class="fw-bold fs-4">@(Model.Stats?.TotalDestroyed ?? 0)</div>
                    <span class="badge bg-secondary">Destroyed</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtres -->
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Plaque</label>
                <input type="text" name="PlateSearch" class="form-control form-control-sm"
                       placeholder="ex: AA-123-BB" value="@Model.PlateSearch" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Statut</label>
                <select name="StatusFilter" class="form-select form-select-sm">
                    <option value="">— Tous —</option>
                    <option value="InStorage" selected="@(Model.StatusFilter == "InStorage" ? "selected" : null)">En fourrière</option>
                    <option value="Released" selected="@(Model.StatusFilter == "Released" ? "selected" : null)">Restitué</option>
                    <option value="Destroyed" selected="@(Model.StatusFilter == "Destroyed" ? "selected" : null)">Détruit</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Agent</label>
                <select name="AgentFilter" class="form-select form-select-sm">
                    <option value="">— Tous —</option>
                    @foreach (var agent in Model.Agents)
                    {
                        <option value="@agent.Id"
                                selected="@(Model.AgentFilter == agent.Id.ToString() ? "selected" : null)">
                            @agent.FullName (@agent.BadgeNumber)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-magnifying-glass me-1"></i>Filtrer
                </button>
                <a asp-page="/Admin/Fourriere/Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-solid fa-xmark me-1"></i>Réinitialiser
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Tableau -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 table-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Plaque</th>
                        <th>Marque / Modèle</th>
                        <th>Couleur</th>
                        <th>Motif</th>
                        <th>Adresse</th>
                        <th>Agent</th>
                        <th>Stockage</th>
                        <th>Date</th>
                        <th class="text-center">Statut</th>
                        <th class="text-end" style="width:160px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Vehicles)
                    {
                        <tr>
                            <td class="fw-semibold font-monospace">@v.PlateNumber</td>
                            <td>
                                <div class="fw-semibold">@v.Make</div>
                                <div class="text-muted small">@v.Model</div>
                            </td>
                            <td class="text-muted small">@v.Color</td>
                            <td>
                                <span class="badge bg-warning text-dark small">
                                    @IndexModel.GetReasonLabel(v.Reason)
                                </span>
                            </td>
                            <td class="small text-muted" style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                title="@v.OriginalAddress">@v.OriginalAddress</td>
                            <td class="small">
                                <i class="fa-solid fa-user-shield me-1 text-secondary"></i>
                                @v.AgentFullName
                                <div class="text-muted" style="font-size:0.7rem">@v.AgentBadgeNumber</div>
                            </td>
                            <td class="small text-muted">@v.StorageLocation</td>
                            <td class="small text-nowrap text-muted">@v.ImpoundedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <span class="badge @IndexModel.GetStatusBadgeClass(v.Status)">
                                    @IndexModel.GetStatusLabel(v.Status)
                                </span>
                            </td>
                            <td class="text-end" style="white-space:nowrap">
                                @if (v.Status == ImpoundStatus.InStorage)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-success me-1"
                                            title="Restituer"
                                            data-bs-toggle="modal"
                                            data-bs-target="#releaseModal"
                                            data-vehicle-id="@v.Id"
                                            data-vehicle-plate="@v.PlateNumber">
                                        <i class="fa-solid fa-key"></i>
                                    </button>
                                    <form asp-page-handler="Destroy" asp-route-id="@v.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Confirmer la destruction du véhicule @v.PlateNumber ?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Détruire">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Vehicles.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-5">
                                <i class="fa-solid fa-warehouse fa-3x mb-3 d-block opacity-25"></i>
                                <p class="mb-0 fw-semibold">Aucun véhicule en fourrière</p>
                                <p class="small">Les enlèvements apparaîtront ici dès qu'ils seront enregistrés.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Restitution -->
<div class="modal fade" id="releaseModal" tabindex="-1" aria-labelledby="releaseModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="releaseModalLabel">
                    <i class="fa-solid fa-key me-2 text-success"></i>Restituer le véhicule
                    <span id="releaseModalPlate" class="text-muted fw-normal ms-1"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="releaseForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="releaseVehicleId" name="id" value="" />
                    <div class="mb-3">
                        <label for="releasedToName" class="form-label fw-semibold">
                            Nom du propriétaire <span class="text-danger">*</span>
                        </label>
                        <input type="text" id="releasedToName" name="releasedToName"
                               class="form-control" placeholder="Prénom NOM" required />
                    </div>
                    <div class="mb-3">
                        <label for="releasedToIdNumber" class="form-label fw-semibold">
                            N° pièce d'identité <span class="text-danger">*</span>
                        </label>
                        <input type="text" id="releasedToIdNumber" name="releasedToIdNumber"
                               class="form-control" placeholder="ex: 123456789012" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="fa-solid fa-key me-1"></i>Confirmer la restitution
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Alimentation du modal de restitution avec l'id et la plaque du véhicule sélectionné
        document.getElementById('releaseModal').addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const vehicleId = btn.getAttribute('data-vehicle-id');
            const plate = btn.getAttribute('data-vehicle-plate');

            document.getElementById('releaseVehicleId').value = vehicleId;
            document.getElementById('releaseModalPlate').textContent = '— ' + plate;

            // Construire l'action du formulaire avec le bon handler
            const form = document.getElementById('releaseForm');
            form.action = '?handler=Release';

            // Réinitialiser les champs
            document.getElementById('releasedToName').value = '';
            document.getElementById('releasedToIdNumber').value = '';
        });
    </script>
}
