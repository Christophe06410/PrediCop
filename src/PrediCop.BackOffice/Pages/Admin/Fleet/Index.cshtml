@page
@model PrediCop.BackOffice.Pages.Admin.Fleet.IndexModel
@using PrediCop.Core.Enums
@{
    ViewData["Title"] = "Gestion de la flotte";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="fa-solid fa-car-on me-2 text-primary"></i>Gestion de la flotte
    </h4>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ---- Alertes flotte ---- *@
@if (Model.Alerts.Count > 0)
{
    <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
        <h6 class="alert-heading fw-bold">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>Alertes maintenance (@Model.Alerts.Count)
        </h6>
        <ul class="mb-0 ps-3">
            @foreach (var alert in Model.Alerts)
            {
                <li>
                    <strong>@alert.VehicleCallSign</strong> (@alert.VehiclePlate) —
                    @alert.Description
                    <span class="badge @(alert.DueDate < DateTime.UtcNow ? "bg-danger" : "bg-warning text-dark") ms-1">
                        @(alert.DueDate < DateTime.UtcNow ? "En retard" : "À venir")
                        · @alert.DueDate.ToString("dd/MM/yyyy")
                    </span>
                </li>
            }
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ---- Onglets ---- *@
<ul class="nav nav-tabs mb-4" id="fleetTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.ActiveTab == "overview" ? "active" : "")"
           asp-page="/Admin/Fleet/Index" asp-route-activeTab="overview">
            <i class="fa-solid fa-gauge-high me-2"></i>Vue d'ensemble
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.ActiveTab == "maintenances" ? "active" : "")"
           asp-page="/Admin/Fleet/Index" asp-route-activeTab="maintenances">
            <i class="fa-solid fa-wrench me-2"></i>Maintenances planifiées
            @if (Model.UpcomingMaintenances.Count > 0)
            {
                <span class="badge bg-warning text-dark ms-1">@Model.UpcomingMaintenances.Count</span>
            }
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model.ActiveTab == "logbook" ? "active" : "")"
           asp-page="/Admin/Fleet/Index" asp-route-activeTab="logbook">
            <i class="fa-solid fa-book me-2"></i>Carnet de bord
        </a>
    </li>
</ul>

@* ---- Vue d'ensemble ---- *@
@if (Model.ActiveTab == "overview")
{
    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">
            <i class="fa-solid fa-list me-2 text-primary"></i>État de la flotte
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Indicatif</th>
                            <th>Plaque</th>
                            <th class="text-end">Km ce mois</th>
                            <th class="text-end">Trajets</th>
                            <th>Prochaine révision</th>
                            <th>Statut maintenance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.VehicleSummaries)
                        {
                            <tr>
                                <td class="fw-bold">
                                    <i class="fa-solid fa-car me-2 text-secondary"></i>@v.CallSign
                                </td>
                                <td class="font-monospace">@v.LicensePlate</td>
                                <td class="text-end">@v.TotalKmThisMonth.ToString("N0") km</td>
                                <td class="text-end">@v.TotalTrips</td>
                                <td>
                                    @if (v.NextMaintenanceDate.HasValue)
                                    {
                                        <span class="@(v.NextMaintenanceDate.Value < DateTime.UtcNow ? "text-danger fw-semibold" : "")">
                                            @v.NextMaintenanceDate.Value.ToString("dd/MM/yyyy")
                                            @if (v.NextMaintenanceType is not null)
                                            {
                                                <span class="text-muted small ms-1">(@IndexModel.GetMaintenanceTypeLabel(Enum.Parse<MaintenanceType>(v.NextMaintenanceType)))</span>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (v.HasOverdueMaintenance)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fa-solid fa-circle-exclamation me-1"></i>En retard
                                        </span>
                                    }
                                    else if (v.NextMaintenanceDate.HasValue && v.NextMaintenanceDate.Value < DateTime.UtcNow.AddDays(30))
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-clock me-1"></i>Bientôt
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="fa-solid fa-circle-check me-1"></i>À jour
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.VehicleSummaries.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                                    Aucun véhicule enregistré.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* ---- Maintenances planifiées ---- *@
@if (Model.ActiveTab == "maintenances")
{
    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">
            <i class="fa-solid fa-wrench me-2 text-primary"></i>Maintenances à venir et en retard
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Véhicule</th>
                            <th>Type</th>
                            <th>Prévue le</th>
                            <th>Description</th>
                            <th>Prestataire</th>
                            <th class="text-end">Coût</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.UpcomingMaintenances)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="fa-solid fa-car me-1 text-secondary"></i>
                                    @m.VehicleCallSign
                                    <span class="text-muted font-monospace small ms-1">@m.VehiclePlate</span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@IndexModel.GetMaintenanceTypeLabel(m.Type)</span>
                                </td>
                                <td class="@(m.IsOverdue ? "text-danger fw-semibold" : "")">
                                    @m.ScheduledDate.ToString("dd/MM/yyyy")
                                </td>
                                <td>@m.Description</td>
                                <td class="text-muted small">@(m.ProviderName ?? "—")</td>
                                <td class="text-end">
                                    @(m.Cost.HasValue ? m.Cost.Value.ToString("N2") + " €" : "—")
                                </td>
                                <td>
                                    @if (m.IsCompleted)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fa-solid fa-circle-check me-1"></i>Effectuée
                                        </span>
                                    }
                                    else if (m.IsOverdue)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fa-solid fa-circle-exclamation me-1"></i>En retard
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-clock me-1"></i>Planifiée
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (!m.IsCompleted)
                                    {
                                        <form method="post" asp-page-handler="CompleteMaintenance" asp-route-id="@m.Id"
                                              class="d-inline"
                                              onsubmit="return confirm('Marquer cette maintenance comme effectuée ?')">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Marquer comme effectuée">
                                                <i class="fa-solid fa-circle-check me-1"></i>Effectuée
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.UpcomingMaintenances.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="fa-solid fa-circle-check fa-2x mb-2 d-block text-success"></i>
                                    Aucune maintenance planifiée ou en retard.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* ---- Carnet de bord ---- *@
@if (Model.ActiveTab == "logbook")
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">
            <i class="fa-solid fa-filter me-2 text-primary"></i>Filtres
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <input type="hidden" name="ActiveTab" value="logbook" />
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Véhicule</label>
                    <select name="VehicleFilter" class="form-select">
                        <option value="">Tous les véhicules</option>
                        @foreach (var v in Model.Vehicles)
                        {
                            <option value="@v.Id" selected="@(Model.VehicleFilter == v.Id)">
                                @v.CallSign (@v.LicensePlate)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Du</label>
                    <input type="date" name="DateFrom" class="form-control" value="@Model.DateFrom" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Au</label>
                    <input type="date" name="DateTo" class="form-control" value="@Model.DateTo" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fa-solid fa-magnifying-glass me-1"></i>Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="fa-solid fa-book me-2 text-primary"></i>Carnet de bord</span>
            <span class="badge bg-secondary">@Model.LogEntries.Count entrée(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Véhicule</th>
                            <th>Agent</th>
                            <th>Date</th>
                            <th class="text-end">Km départ</th>
                            <th class="text-end">Km arrivée</th>
                            <th class="text-end">Total km</th>
                            <th class="text-end">Carburant (L)</th>
                            <th>Destination</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.LogEntries)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="fa-solid fa-car me-1 text-secondary"></i>
                                    @e.VehicleCallSign
                                    <span class="text-muted font-monospace small ms-1">@e.VehiclePlate</span>
                                </td>
                                <td>
                                    <i class="fa-solid fa-user me-1 text-secondary"></i>@e.OfficerFullName
                                </td>
                                <td>@e.Date.ToString("dd/MM/yyyy")</td>
                                <td class="text-end font-monospace">@e.KmStart.ToString("N0")</td>
                                <td class="text-end font-monospace">@e.KmEnd.ToString("N0")</td>
                                <td class="text-end fw-semibold">
                                    <span class="badge bg-primary">+@e.KmTotal.ToString("N0") km</span>
                                </td>
                                <td class="text-end">
                                    @(e.FuelAdded.HasValue ? e.FuelAdded.Value.ToString("N1") + " L" : "—")
                                </td>
                                <td class="text-muted small">@(e.Destination ?? "—")</td>
                                <td class="text-muted small">@(e.Notes ?? "—")</td>
                            </tr>
                        }
                        @if (!Model.LogEntries.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    <i class="fa-solid fa-inbox fa-2x mb-2 d-block"></i>
                                    Aucune entrée de carnet de bord pour ces critères.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
