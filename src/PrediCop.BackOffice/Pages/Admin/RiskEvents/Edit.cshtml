@page "{id:guid?}"
@model PrediCop.BackOffice.Pages.Admin.RiskEvents.EditModel
@{
    var isNew = Model.EventId == null;
    ViewData["Title"] = isNew ? "Nouvel événement de risque" : "Modifier l'événement de risque";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Admin/RiskEvents/Index">Événements de risque</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>
    <a asp-page="/Admin/RiskEvents/Index" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Retour
    </a>
</div>

@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-exclamation me-1"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0 fw-semibold">
                    <i class="fa-solid fa-triangle-exclamation me-2 text-warning"></i>
                    @(isNew ? "Créer un événement de risque" : "Modifier l'événement")
                </h6>
            </div>
            <div class="card-body">
                <form method="post" asp-route-id="@Model.EventId">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Rue <span class="text-danger">*</span></label>
                        <select asp-for="StreetId" class="form-select" required>
                            <option value="">— Sélectionner une rue —</option>
                            @foreach (var s in Model.Streets)
                            {
                                <option value="@s.Id" selected="@(Model.StreetId == s.Id)">
                                    @s.Name@(s.District != null ? $" — {s.District}" : "")
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">
                            Titre <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control" placeholder="Ex : Marché hebdomadaire" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Description de l'événement..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RiskPoints" class="form-label fw-semibold">
                            Points de risque <span class="text-danger">*</span>
                        </label>
                        <input asp-for="RiskPoints" type="number" class="form-control"
                               min="1" max="100" required />
                        <div class="form-text">Nombre de points ajoutés au score de risque de la rue.</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="EventDate" class="form-label fw-semibold">
                                Date de l'événement <span class="text-danger">*</span>
                            </label>
                            <input asp-for="EventDate" type="datetime-local" class="form-control"
                                   value="@Model.EventDate.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExpiresAt" class="form-label fw-semibold">
                                Date d'expiration <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ExpiresAt" type="datetime-local" class="form-control"
                                   value="@Model.ExpiresAt.ToString("yyyy-MM-ddTHH:mm")" required />
                            <div class="form-text">Le risque s'applique jusqu'à cette date.</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Source" class="form-label fw-semibold">Source</label>
                        <input asp-for="Source" class="form-control"
                               placeholder="Ex : Mairie, Préfecture, Signal citoyen..." />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk me-2"></i>@(isNew ? "Créer l'événement" : "Enregistrer")
                        </button>
                        <a asp-page="/Admin/RiskEvents/Index" class="btn btn-outline-secondary">
                            <i class="fa-solid fa-xmark me-1"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
