@page
@model PrediCop.BackOffice.Pages.Admin.RiskEvents.IndexModel
@{
    ViewData["Title"] = "Événements de risque";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="fa-solid fa-triangle-exclamation me-2 text-warning"></i>Événements de risque planifiés
    </h4>
    <a asp-page="/Admin/RiskEvents/Edit" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-plus me-1"></i>Ajouter un événement
    </a>
</div>

@if (TempData["SuccessMessage"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-1"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-exclamation me-1"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filtres -->
<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold mb-1">Rue</label>
                <select name="StreetFilter" class="form-select form-select-sm">
                    <option value="">— Toutes les rues —</option>
                    @foreach (var s in Model.Streets)
                    {
                        <option value="@s.Id" selected="@(Model.StreetFilter == s.Id)">
                            @s.Name@(s.District != null ? $" ({s.District})" : "")
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold mb-1">Recherche titre</label>
                <input type="text" name="SearchTitle" class="form-control form-control-sm"
                       placeholder="Titre..." value="@Model.SearchTitle" />
            </div>
            <div class="col-md-2 d-flex align-items-center gap-2 pt-3">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" name="ActiveOnly" id="chkActive"
                           value="true" @(Model.ActiveOnly ? "checked" : "") />
                    <label class="form-check-label small" for="chkActive">Actifs seulement</label>
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-filter me-1"></i>Filtrer
                </button>
                <a asp-page="/Admin/RiskEvents/Index" class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-xmark me-1"></i>Réinitialiser
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (Model.Events.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="fa-solid fa-triangle-exclamation fa-3x mb-3 opacity-25"></i>
                <p class="mb-1 fw-semibold">Aucun événement de risque</p>
                <p class="small">Créez des événements planifiés (marchés, fêtes, etc.) pour modérer le risque des rues.</p>
                <a asp-page="/Admin/RiskEvents/Edit" class="btn btn-primary btn-sm mt-2">
                    <i class="fa-solid fa-plus me-1"></i>Ajouter un événement
                </a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Rue</th>
                        <th>Titre</th>
                        <th class="d-none d-lg-table-cell">Description</th>
                        <th class="text-center">Points</th>
                        <th class="text-center d-none d-md-table-cell">Date événement</th>
                        <th class="text-center d-none d-md-table-cell">Expire le</th>
                        <th class="d-none d-lg-table-cell">Source</th>
                        <th class="text-center">Actif</th>
                        <th class="text-end" style="width:120px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model.Events)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold small">@e.StreetName</div>
                                @if (!string.IsNullOrEmpty(e.StreetDistrict))
                                {
                                    <div class="text-muted" style="font-size:.75rem">@e.StreetDistrict</div>
                                }
                            </td>
                            <td class="fw-semibold">@e.Title</td>
                            <td class="text-muted small d-none d-lg-table-cell" style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                @(string.IsNullOrEmpty(e.Description) ? "—" : e.Description)
                            </td>
                            <td class="text-center">
                                <span class="badge bg-danger">+@e.RiskPoints</span>
                            </td>
                            <td class="text-center small d-none d-md-table-cell">
                                @e.EventDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="text-center small d-none d-md-table-cell">
                                @e.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="small d-none d-lg-table-cell">@(string.IsNullOrEmpty(e.Source) ? "—" : e.Source)</td>
                            <td class="text-center">
                                @if (e.IsActive)
                                {
                                    <span class="badge bg-success">Oui</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Non</span>
                                }
                            </td>
                            <td class="text-end" style="white-space:nowrap">
                                <a asp-page="/Admin/RiskEvents/Edit" asp-route-id="@e.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Modifier">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form asp-page-handler="Delete"
                                      asp-route-streetId="@e.StreetId"
                                      asp-route-eventId="@e.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Supprimer l\'événement « @e.Title » ?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
